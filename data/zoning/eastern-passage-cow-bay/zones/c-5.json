  "content_blocks": [
    {
      "heading_context_raw": null,
      "text": "No development permit shall be issued in any C -5 (Mixed Use) Zone, except for the"
    },
    {
      "heading_context_raw": "following:",
      "text": ""
    },
    {
      "heading_context_raw": "15.2 C-5 ZONE REQUIREMENTS",
      "text": "In any C -5 Zone, no development permit shall be issued except in conformity with the"
    },
    {
      "heading_context_raw": "following:",
      "text": "Minimum Lot Area 6,000 square feet (557.4 m2) Minimum Frontage 60 feet (18.3 m) Minimum Front or Flankage Yard 20 feet (6.1 m) Minimum Rear or Side Yard 8 feet (2.4 m) Maximum Lot Coverage 50 per cent Maximum Height of Main Building 35 feet (10.7 m)"
    },
    {
      "heading_context_raw": "15.3 OTHER REQUIREMENTS: COMMERCIAL AND INDUSTRIAL USES",
      "text": "Where uses are permitted as Commercial Uses or Industrial Service Uses in any C-5 Zone,"
    },
    {
      "heading_context_raw": "the following shall apply:",
      "text": "(a) The gross floor area of any commercial building, including any floor area devoted to permitted dwelling units, shall not exceed five thousand (5,000) square feet (464.5 m2). (b) The area devoted to open storage or outdoor display shall not exceed fifty (50) percent of the lot area. (c) No open storage or outdoor display shall be permitted within ten (10) feet (3.0 m) of any lot line."
    },
    {
      "heading_context_raw": "15.3A OTHER REQUIREMENTS: BED AND BREAKFAST ESTABLISHMENTS",
      "text": "DELETED (RC-Feb 21/23;E-Sept 01/23)"
    },
    {
      "heading_context_raw": "15.4 C-5 ZONE REQUIREMENTS: COMMUNITY USES",
      "text": "In any C -5 Zone, where uses are permitted as Community Uses, no development permit shall be issued except in conformity with the provisions of Part 23."
    }
  ],
