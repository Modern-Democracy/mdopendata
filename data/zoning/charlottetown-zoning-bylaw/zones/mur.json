    {
      "order_index": 2,
      "section_label_raw": "21.2",
      "title_label_raw": "REGULATIONS FOR MIXED DENSITY DISTRIBUTION",
      "citations": {
        "pdf_page_start": 80,
        "pdf_page_end": 81,
        "bylaw_page_start": 80,
        "bylaw_page_end": 81
      },
      "provisions": [
        {
          "provision_label_raw": "21.2.1",
          "clause_path": [
            "21.2.1"
          ],
          "text": "Development within the MUR Zone is meant to be of a mixed variety of building forms and Semi-detached or Duplex Dwellings, Single-detached Dwellings, Nursing Homes and Community Care Facilities.",
          "status": "active",
          "citations": {
            "pdf_page_start": 80,
            "pdf_page_end": 80,
            "bylaw_page_start": 80,
            "bylaw_page_end": 80
          }
        },
        {
          "provision_label_raw": "21.2.2",
          "clause_path": [
            "21.2.2"
          ],
          "text": "Within the MUR Zone the following Building forms shall be permitted on any Block in the percentages indicated:",
          "status": "active",
          "citations": {
            "pdf_page_start": 80,
            "pdf_page_end": 80,
            "bylaw_page_start": 80,
            "bylaw_page_end": 80
          }
        },
        {
          "provision_label_raw": "a",
          "clause_path": [
            "21.2.2",
            "a"
          ],
          "text": "Semi-detached and Duplex Dwellings shall be permitted on up to 25% of the Lots; 25% of the Lots;",
          "status": "active",
          "citations": {
            "pdf_page_start": 80,
            "pdf_page_end": 80,
            "bylaw_page_start": 80,
            "bylaw_page_end": 80
          }
        },
        {
          "provision_label_raw": "c",
          "clause_path": [
            "21.2.2",
            "c"
          ],
          "text": "Single-detached Dwellings shall be permitted on up to 35% of the Lots; and",
          "status": "active",
          "citations": {
            "pdf_page_start": 80,
            "pdf_page_end": 80,
            "bylaw_page_start": 80,
            "bylaw_page_end": 80
          }
        },
        {
          "provision_label_raw": "d",
          "clause_path": [
            "21.2.2",
            "d"
          ],
          "text": "Institutional Uses as permitted in the R-3 Zone shall be permitted on up to 15% of the Lots. However, if the percentage for Institutional Uses is not used than the percentage allocated to this use can be allocated in 1/3 increments for the remaining uses as stipulated in this section or the remaining portion can be allocated in whole to Single-detached Dwellings.",
          "status": "active",
          "citations": {
            "pdf_page_start": 80,
            "pdf_page_end": 80,
            "bylaw_page_start": 80,
            "bylaw_page_end": 80
          }
        },
        {
          "provision_label_raw": "21.2.3",
          "clause_path": [
            "21.2.3"
          ],
          "text": "Single-detached, Semi-detached and Duplex Dwellings shall be permitted on adjoining Lots on the same side of the street adjacent to townhouse Dwellings. At least one side of a run of semi- detached or duplex Dwelling must be flanked by a Single-detached Dwelling.",
          "status": "active",
          "citations": {
            "pdf_page_start": 80,
            "pdf_page_end": 80,
            "bylaw_page_start": 80,
            "bylaw_page_end": 80
          }
        },
        {
          "provision_label_raw": "21.2.4",
          "clause_path": [
            "21.2.4"
          ],
          "text": "No more than three (3) Townhouse Dwellings with a maximum of twelve (12) units total on all three (3) lots shall be permitted to be constructed on adjoining Lots on the same side of the street.",
          "status": "active",
          "citations": {
            "pdf_page_start": 80,
            "pdf_page_end": 80,
            "bylaw_page_start": 80,
            "bylaw_page_end": 80
          }
        },
        {
          "provision_label_raw": "21.2.5",
          "clause_path": [
            "21.2.5"
          ],
          "text": "At no time shall more than two (2) Townhouse Dwelling consisting of more than six (6) Dwelling Units be permitted to be constructed on adjoining Lots.",
          "status": "active",
          "citations": {
            "pdf_page_start": 81,
            "pdf_page_end": 81,
            "bylaw_page_start": 81,
            "bylaw_page_end": 81
          }
        },
        {
          "provision_label_raw": "21.2.6",
          "clause_path": [
            "21.2.6"
          ],
          "text": "Subdivision of land within the MUR Zone shall be undertaken in Phases. Prior to approval of a Subdivision within the MUR Zone a concept plan shall be submitted for the overall parcel. The concept plan shall indicate the Phases of Development and shall ensure the mixed density formula has been satisfied for the overall parcel of land.",
          "status": "active",
          "citations": {
            "pdf_page_start": 81,
            "pdf_page_end": 81,
            "bylaw_page_start": 81,
            "bylaw_page_end": 81
          }
        }
      ],
