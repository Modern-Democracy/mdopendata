          "provision_label_raw": "12.2.1",
          "clause_path": [
            "12.2.1"
          ],
          "text": "A Mini-home/Modular Dwelling Development or Mini-home/Modular Dwelling Subdivision shall be located on a designated site that is not less than 3.0 hectares (7.41 acres) in Lot Area.",
