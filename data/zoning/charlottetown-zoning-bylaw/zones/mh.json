        {
          "provision_label_raw": "12.2.2",
          "clause_path": [
            "12.2.2"
          ],
          "text": "Mini-home or Modular Dwelling Developments shall not have a density greater than 20 units per hectare.",
          "status": "active",
          "citations": {
