        {
          "provision_label_raw": "12.2.3",
          "clause_path": [
            "12.2.3"
          ],
          "text": "Private streets within a Mini-home or Modular Dwelling Development shall have a minimum paved surface width of 7.3 m and have an overall Right-of-way width of 10.7 m (35.1 ft)",
