    {
      "order_index": 2,
      "section_label_raw": "45.2",
      "title_label_raw": "REGULATIONS FOR THE FUTURE DEVELOPMENT (FD) ZONE",
      "citations": {
        "pdf_page_start": 122,
        "pdf_page_end": 122,
        "bylaw_page_start": 122,
        "bylaw_page_end": 122
      },
      "provisions": [
        {
          "provision_label_raw": "45.2.1",
          "clause_path": [
            "45.2.1"
          ],
          "text": "The Future Development (FD) Zone is meant to preserve land for future urban Development that has not yet been connected to Municipal Services. A limited number of uses are permitted within the Zone until servicing becomes available and Council deems it appropriate for Development.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        },
        {
          "provision_label_raw": "45.2.2",
          "clause_path": [
            "45.2.2"
          ],
          "text": "A property owner may submit a proposal for Subdivision within the FD Zone. Such a proposal shall be presented in the form of a Development Concept Plan. The Development Concept Plan shall be reviewed to determine if it is an appropriate proposal, based on factors such as:",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        },
        {
          "provision_label_raw": "a",
          "clause_path": [
            "45.2.2",
            "a"
          ],
          "text": "Location of servicing in proximity to the parcel of land;",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        },
        {
          "provision_label_raw": "b",
          "clause_path": [
            "45.2.2",
            "b"
          ],
          "text": "Availability of land currently serviced and ready for Development;",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        },
        {
          "provision_label_raw": "c",
          "clause_path": [
            "45.2.2",
            "c"
          ],
          "text": "Existing and future road networks; and",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        },
        {
          "provision_label_raw": "d",
          "clause_path": [
            "45.2.2",
            "d"
          ],
          "text": "Any other factors Council deems appropriate and necessary in making a determination.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        },
        {
          "provision_label_raw": "45.2.3",
          "clause_path": [
            "45.2.3"
          ],
          "text": "Applications for Subdivision and Development for any land use not listed in the Permitted Uses for this Zone, shall follow the same process for approval as an amendment to this by-law for a Rezoning, OR that process to described for a Development Concept Plan in the Comprehensive Development Area (CDA) Zone.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        },
        {
          "provision_label_raw": "45.2.4",
          "clause_path": [
            "45.2.4"
          ],
          "text": "Council shall require the applicant/landowner to enter into a Development Agreement upon approval of a Development Concept Plan.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 122,
            "bylaw_page_end": 122
          }
        }
