        },
        {
          "provision_label_raw": "c",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any real estate sign which has an area of no more than eight (8) square feet (0.7"
        },
