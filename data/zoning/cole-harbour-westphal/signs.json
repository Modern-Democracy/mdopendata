          "provision_label_raw": "m2",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "in any residential zone or twenty -four (24) square feet (2.2 m 2) in any other zone."
        },
        {
          "provision_label_raw": "d",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign which has an area of no more than five (5) square feet (0.5 m2) and which regulates or denotes the direction or function of various parts of a building or premises, including parking and traffic areas."
        },
        {
          "provision_label_raw": "e",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign which has an area of no more than fifty (50) square feet (4.6 m 2) and which is incidental to construction."
        },
        {
          "provision_label_raw": "f",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign erected by, or under the direction of, a government body as are signs identifying public buildings, giving public information or regulating traffic or safety."
        },
        {
          "provision_label_raw": "g",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any flag, insignia, notice or advertising of any charitable, religious or fraternal organization."
        },
        {
          "provision_label_raw": "h",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any memorial sign, plaque or tablet."
        }
      ]
    },
    {
      "order_index": 7,
      "section_label_raw": "5.6",
      "title_label_raw": "SIGNS PROHIBITED IN ALL ZONES",
      "citations": {
        "pdf_page_start": 53,
        "pdf_page_end": 54,
        "bylaw_page_start": 45,
        "bylaw_page_end": 46
