      "provisions": [
        {
          "provision_label_raw": "5.7",
          "text": "No facial wall sign shall cover more than one (1) square foot (0.1 m2) per lineal foot of the wall on which the sign is affixed, such coverage to be allocated proportionally for each business premises in the case of multiple occupancy buildings. In no case however, shall the total area of the facial wall sign for any busine ss premises exceed one hundred (100) square feet (9.3 m2).",
          "status": "active",
          "citations": {
            "pdf_page_start": 54,
