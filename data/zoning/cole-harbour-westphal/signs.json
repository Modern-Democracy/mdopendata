            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign or sign structure which constitutes a hazard to public safety or health."
        },
        {
          "provision_label_raw": "b",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign which, for any reason, obstructs the vision of drivers leaving a roadway or driveway, or detracts from the visibility or effectiveness of any traffic sign or control device on public streets."
        },
        {
          "provision_label_raw": "c",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign which obstructs free ingress to or egress from a fire escape door, window or other required exit."
        },
        {
          "provision_label_raw": "d",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign located at or near a sharp road curve or below the crest of a hill, except a sign erected by a government body."
        },
        {
          "provision_label_raw": "e",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign which is not erected by, or under the direction of, a government body and which makes use of words such as \"STOP\", \"LOOK\", \"DANGER\", \"ONE WAY\" or \"YIELD\" or any similar words, phrases, symbols, lights or characters used in a manner which may misl ead, confuse or otherwise interfere with traffic along a public road."
        },
        {
          "provision_label_raw": "f",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign which incorporates any flashing or moving illumination and any sign which has any visible moving part or mechanical movement whether achieved by natural or artificial means."
        },
        {
          "provision_label_raw": "g",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any searchlight, stringlight, spinner or streamer except for occasions such as grand openings, county fairs and public festivals, or used as temporary holiday decorations."
        },
        {
          "provision_label_raw": "h",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 53,
            "pdf_page_end": 53,
            "bylaw_page_start": 45,
            "bylaw_page_end": 45
          },
          "text": "Any sign painted on a tree, stone, cliff or other natural object."
        },
        {
          "provision_label_raw": "i",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 54,
            "pdf_page_end": 54,
            "bylaw_page_start": 46,
            "bylaw_page_end": 46
          },
          "text": "Any sign which is not related to any business or use located on the lot or premises, and any sign which no longer advertises a bona fide business conducted or a product"
        },
        {
          "provision_label_raw": "sold",
          "clause_path": null,
          "status": "active",
          "citations": {
            "pdf_page_start": 54,
            "pdf_page_end": 54,
            "bylaw_page_start": 46,
            "bylaw_page_end": 46
          },
          "text": "Such signs are deemed to be obsolete signs and shall be removed by the owner or occupant of the property upon which they are erected, within sixty (60) days of the date of discontinuance of the business or product."
        }
      ]
    },
    {
      "order_index": 8,
      "section_label_raw": "5.7",
      "title_label_raw": "FACIAL WALL SIGNS",
