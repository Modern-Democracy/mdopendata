        ],
        "use_name": "built form requirements",
        "controls": [
          {
            "clause_label_raw": "38CC(1)(a)",
            "clause_path": [
              "38CC",
              "1",
              "a"
            ],
            "condition_text": "streetwall shall be set back from the streetline a minimum of 1.5 metres and a maximum of 6.5 metres"
          },
          {
            "clause_label_raw": "38CC(1)(b)",
            "clause_path": [
              "38CC",
              "1",
              "b"
            ],
            "condition_text": "maximum streetwall height shall be 3 storeys from street line grade",
            "subcontrols": [
              {
                "clause_label_raw": "38CC(1)(b)(i)",
                "clause_path": [
                  "38CC",
                  "1",
                  "b",
                  "i"
                ],
                "condition_text": "maximum streetwall height may be exceeded by a clear uncoloured glass guard and railing system to allow safe use of podiums and rooftops by occupants"
              }
            ]
          },
          {
            "clause_label_raw": "38CC(1)(c)",
            "clause_path": [
              "38CC",
              "1",
              "c"
            ],
            "condition_text": "for a building located on Herring Cove Road, the streetwall length on Herring Cove Road shall extend a minimum of 65 percent of the lot frontage"
          },
          {
            "clause_label_raw": "38CC(1)(d)",
            "clause_path": [
              "38CC",
              "1",
              "d"
            ],
            "condition_text": "a minimum setback of 6 metres shall be provided between side and rear lot lines and the portion of the building above parking structures"
          },
          {
            "clause_label_raw": "38CC(1)(e)",
            "clause_path": [
              "38CC",
              "1",
              "e"
            ],
            "condition_text": "above the streetwall, the building shall be stepped back a minimum of 3 metres for all portions above the streetwall height facing street lines"
          },
          {
            "clause_label_raw": "38CC(1)(f)",
            "clause_path": [
              "38CC",
              "1",
              "f"
            ],
            "condition_text": "the overall building shall not exceed seven storeys"
          },
          {
            "clause_label_raw": "38CC(1)(g)",
            "clause_path": [
              "38CC",
              "1",
              "g"
            ],
            "condition_text": "the maximum height requirement in 38CC(1)(f) does not apply to the listed rooftop and similar features, provided:",
            "subcontrols": [
              {
                "clause_label_raw": "38CC(1)(g)(i)",
                "clause_path": [
                  "38CC",
                  "1",
                  "g",
                  "i"
                ],
                "condition_text": "the total of all such features shall occupy in the aggregate less than 30 percent of the roof area"
              },
              {
                "clause_label_raw": "38CC(1)(g)(ii)",
                "clause_path": [
                  "38CC",
                  "1",
                  "g",
                  "ii"
                ],
                "condition_text": "such features shall be setback no less than 3 metres from the outermost edge of the roof, except no setback is required for clock towers, parapets, cornices and similar architectural features"
              }
            ]
          },
          {
            "clause_label_raw": "38CC(1)(h)",
            "clause_path": [
              "38CC",
              "1",
              "h"
            ],
            "condition_text": "above a height of 3 storeys, the building depth shall not exceed 25 metres; for a corner lot with frontage on Herring Cove Road, the front lot line is considered the street line with Herring Cove Road"
          }
        ]
      },
      {
        "section_label_raw": "38CD(1)",
        "section_path": [
          "38CD",
          "1"
        ],
        "controls": [
          {
            "clause_label_raw": "38CD(1)(a)",
            "clause_path": [
              "38CD",
              "1",
              "a"
            ],
            "condition_text": "maximum lot coverage shall be 75 percent, except that parking structures below grade or extending no more than an average of 1 metre above grade may cover 100 percent of the lot area"
          }
        ]
      }
    ],
