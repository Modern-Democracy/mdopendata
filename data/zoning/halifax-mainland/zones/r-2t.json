      "controls": [
        {
          "clause_label_raw": "28AM(a)",
          "clause_path": [
            "28AM",
            "a"
          ],
          "conditions": [
            "a townhouse building may be subdivided so each townhouse is on its own lot if the minimum requirements of 28AL(2) are met",
            "no side yard is required along the common lot boundary dividing the townhouse building"
          ]
        },
        {
          "clause_label_raw": "28AM(b)",
          "clause_path": [
            "28AM",
            "b"
          ],
          "conditions": [
            "notwithstanding 28AL(2)(a), townhouse buildings existing on the date of adoption of this provision may be subdivided so each townhouse is on its own lot if each lot has at least 10 feet of frontage on a street",
            "no side yard is required along the common boundary dividing the townhouse building"
          ]
        }
      ]
    },
