  "use_specific_standards": [
    {
      "use_name": "348 Purcell's Cove Road site-specific rules",
      "standards": [
        {
          "section_label_raw": "61(5)",
          "section_path": [
            "61",
            "5"
          ],
          "rule_type": "notwithstanding_override",
          "condition_text": "Notwithstanding the definitions of accessory building and accessory use in Section 2, Sections 14A, 14C, and 14U, clauses 21(a), 21(b), 21(ba), 21(e), 21(f) and 21(g), and subsections 61(1), 61(2), 61(3), and 61(4), the following shall apply to Lots G1, G2 and a portion of a water lot located at 348 Purcell's Cove Road, Halifax, shown on Map ZM-27.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            },
            {
              "source_text": "accessory use",
              "definition_key": "accessory_use",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(a)",
          "clause_path": [
            "61",
            "5",
            "a"
          ],
          "condition_text": "An existing single family dwelling and an accessory building shall be permitted on Lot G2 (PID #41158452) and a portion of a water lot (PID #00633511) as shown on Map ZM-27. No additions increasing floor area on Lot G2 shall be permitted. No new buildings on Lot G2 shall be permitted. Repairs, renovations, and replacement of buildings existing on the effective date of this provision on Lot G2 are permitted.",
          "text_defined_term_refs": [
            {
              "source_text": "single family dwelling",
              "definition_key": "single_family_dwelling",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            },
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(b)(i)(A)",
          "clause_path": [
            "61",
            "5",
            "b",
            "i",
            "A"
          ],
          "condition_text": "An accessory building existing on the effective date of this provision and located in the northern corner of Lot G1 (PID #00270975) shall be permitted to be accessory to the dwelling located on Lot G2.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(b)(i)(B)",
          "clause_path": [
            "61",
            "5",
            "b",
            "i",
            "B"
          ],
          "condition_text": "The accessory building in the northern corner of Lot G1 may have a maximum height of three storeys and a maximum of thirty feet.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(b)(i)(C)",
          "clause_path": [
            "61",
            "5",
            "b",
            "i",
            "C"
          ],
          "condition_text": "The accessory building in the northern corner of Lot G1 may have a minimum setback of zero feet from a side or rear property line, as shown on Map ZM-27.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(b)(ii)",
          "clause_path": [
            "61",
            "5",
            "b",
            "ii"
          ],
          "condition_text": "The accessory building in the northern corner of Lot G1 shall not be occupied at any time as a dwelling.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(b)(iii)",
          "clause_path": [
            "61",
            "5",
            "b",
            "iii"
          ],
          "condition_text": "No additions increasing floor area or existing height of the accessory building in the northern corner of Lot G1 shall be permitted.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(b)(iv)",
          "clause_path": [
            "61",
            "5",
            "b",
            "iv"
          ],
          "condition_text": "Repairs, renovations, and replacement of the accessory building in the northern corner of Lot G1 are permitted.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(c)",
          "clause_path": [
            "61",
            "5",
            "c"
          ],
          "condition_text": "An existing accessory building located on the eastern side of Lot G1 (PID #00270975) may have a minimum setback of zero feet from a side or rear property line, as shown on Map ZM-27. Additions to this building shall comply with clause 21(f) and shall have a maximum height of fourteen feet.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(d)",
          "clause_path": [
            "61",
            "5",
            "d"
          ],
          "condition_text": "The southernmost accessory building on Lot G1 may expand subject to compliance with clause 21(f) and a maximum height of fourteen feet.",
          "text_defined_term_refs": [
            {
              "source_text": "accessory building",
              "definition_key": "accessory_building",
              "source_field": "condition_text",
              "link_method": "reviewed_text_match"
            }
          ]
        },
        {
          "clause_label_raw": "61(5)(e)",
          "clause_path": [
            "61",
            "5",
            "e"
          ],
          "condition_text": "New accessory buildings on Lot G1 that are accessory to the dwelling located on Lot G2 shall comply with Section 21 and shall have a maximum height of fourteen feet."
        },
        {
          "clause_label_raw": "61(5)(f)",
          "clause_path": [
            "61",
            "5",
            "f"
          ],
          "condition_text": "Clauses 61(5)(a), 61(5)(b), 61(5)(c), 61(5)(d), 61(5)(e) and subsection 62EE(7) do not exempt the existing buildings from approvals from any agency or government that may be necessary to obtain municipal permits."
        }
      ]
    }
