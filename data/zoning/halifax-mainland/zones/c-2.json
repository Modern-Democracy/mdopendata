  "requirements": {
    "c2_use_controls": [
      {
        "section_label_raw": "41",
        "section_path": [
          "41"
        ],
        "use_name": "C-1, C-2A or C-2 uses in a C-2 Zone",
        "controls": [
          {
            "clause_label_raw": "41(a)",
            "clause_path": [
              "41",
              "a"
            ],
            "condition_text": "maximum lot coverage is 50 percent, except motel building or buildings shall occupy not more than 30 percent of the total building lot area"
          },
          {
            "clause_label_raw": "41(b)",
            "clause_path": [
              "41",
              "b"
            ],
            "controls": [
              {
                "clause_label_raw": "41(b)(i)",
                "clause_path": [
                  "41",
                  "b",
                  "i"
                ],
                "condition_text": "every building shall be at least 12 feet from every other building and at least 8 feet from the rear and both side lines of the lot and at least 20 feet from any street line in front of such building"
              },
              {
                "clause_label_raw": "41(b)(ii)",
                "clause_path": [
                  "41",
                  "b",
                  "ii"
                ],
                "condition_text": "where the building is situated on a corner lot, it shall be at least 10 feet from the flanking street line abutting such lot"
              }
            ]
          },
          {
            "clause_label_raw": "41(c)",
            "clause_path": [
              "41",
              "c"
            ],
            "condition_text": "notwithstanding clause (b), the building is exempt from side building line requirements and distance requirements from other buildings where the following apply",
            "subcontrols": [
              {
                "clause_label_raw": "41(c)(i)",
                "clause_path": [
                  "41",
                  "c",
                  "i"
                ],
                "condition_text": "the sidewalls of the building are fireproof to comply with the Building By-law of the city"
              },
              {
                "clause_label_raw": "41(c)(ii)",
                "clause_path": [
                  "41",
                  "c",
                  "ii"
                ],
                "condition_text": "the abutting lot is not a lot in a residential zone used for residential purposes"
              }
            ]
          }
        ]
      },
      {
        "section_label_raw": "41A(1)",
        "section_path": [
          "41A",
          "1"
        ],
        "applicability_scope": "mainland_south_area_only",
        "controls": [
          {
            "clause_label_raw": "41A(1)(a)",
            "clause_path": [
              "41A",
              "1",
              "a"
            ],
            "condition_text": "buildings, parking, service areas, and circulation lanes must be a minimum of 30 feet from any rear or side lot line abutting a residential zone",
            "exception_text": "except for building, such setbacks are not required where screening in the form of a solid fence or vegetative hedging is provided"
          },
          {
            "clause_label_raw": "41A(1)(b)",
            "clause_path": [
              "41A",
              "1",
              "b"
            ],
            "condition_text": "no vehicular access shall be obtained through a side or rear yard adjacent to a residential zone"
