      "section_path": [
        "28CI",
        "1"
      ],
      "use_name": "unit mix in the Mainland South Area",
      "applicability_scope": "mainland_south_area_only",
      "conditions": [
        "an apartment house located in the Mainland South Area shall provide one two-bedroom unit for every three bachelor and/or one-bedroom units"
      ]
    },
