      "section_label_raw": "28CI(2)",
      "section_path": [
        "28CI",
        "2"
      ],
      "use_name": "unit mix timing exception",
      "conditions": [
        "notwithstanding 28CI(1), bedroom-count requirements do not apply for any residential multi-unit dwelling use that begins construction before 2028-04-01"
      ]
    },
    {
      "section_label_raw": "28CJ",
      "section_path": [
        "28CJ"
      ],
      "use_name": "yards, landscaping and screening in Mainland South",
      "applicability_scope": "mainland_south_area_only",
      "conditions": [
        "for properties zoned R-3 on or after the effective date of this section, the following apply to new apartment houses"
      ],
      "controls": [
        {
          "clause_label_raw": "28CJ(a)",
          "clause_path": [
            "28CJ",
            "a"
          ],
          "condition_text": "notwithstanding 28CE(2)(b), the minimum side or rear yard abutting low-density and medium-density residential uses shall be 20 feet and shall otherwise adhere to the angular planes in 28CE(2) and 28CE(3)"
        },
        {
          "clause_label_raw": "28CJ(b)",
          "clause_path": [
            "28CJ",
            "b"
          ],
          "condition_text": "the minimum 20 foot side or rear yard shall consist of a landscaped area providing visual screening and may include opaque fencing at least 6 feet high",
          "exception_text": "the landscaped area may include pedestrian walkways, landscaped open space and recreational space but shall not include vehicular driveways, parking or loading spaces, storage or refuse containers, or buildings"
        }
      ]
    },
    {
      "section_label_raw": "28CK",
      "section_path": [
        "28CK"
      ],
      "use_name": "commercial uses fronting on Herring Cove Road",
      "conditions": [
        "notwithstanding 28CA(1), an apartment house or shared housing use fronting on Herring Cove Road may include commercial uses permitted in 34AA(1)(c) as well as offices"
      ],
      "controls": [
        {
          "clause_label_raw": "28CK(a)",
          "clause_path": [
            "28CK",
            "a"
          ],
          "condition_text": "commercial uses shall be located on the ground floor and limited to a maximum of 2,000 square feet of gross commercial floor area"
        },
        {
          "clause_label_raw": "28CK(b)",
          "clause_path": [
            "28CK",
            "b"
          ],
          "condition_text": "exterior access to commercial uses shall be separate from access to residential uses"
        },
        {
          "clause_label_raw": "28CK(c)",
          "clause_path": [
            "28CK",
            "c"
          ],
          "condition_text": "one sign is permitted for each commercial use, not exceeding 3 feet in height, limited to the space immediately above the ground-floor store windows",
          "exception_text": "signs shall be non-illuminated, front illuminated, or have back-lighted lettering"
        },
        {
          "clause_label_raw": "28CK(d)",
          "clause_path": [
            "28CK",
            "d"
          ],
          "condition_text": "vehicular parking for commercial uses shall be provided pursuant to Section 9(d) in addition to parking required for residential uses",
          "exception_text": "notwithstanding Section 14, no loading space is required"
        }
      ]
    }
