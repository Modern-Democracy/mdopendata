    "four_storey_apartment_controls": [
      {
        "section_label_raw": "28CE",
        "section_path": [
          "28CE"
        ],
        "use_name": "apartment buildings with more than four units and four storeys or less",
        "conditions": [
          "permitted in an R-3 Zone if the following requirements are complied with"
        ],
        "controls": [
          {
            "section_label_raw": "28CE(1)",
            "section_path": [
              "28CE",
              "1"
            ],
            "metric_group": "minimum_lot_area_and_frontage",
            "controls": [
              {
                "metric": "lot_area_minimum",
                "value": 6000,
                "unit": "sq_ft"
              },
              {
                "metric": "continuous_street_frontage_minimum",
                "value": 60,
                "unit": "ft"
              }
            ]
          },
          {
            "section_label_raw": "28CE(2)",
            "section_path": [
              "28CE",
              "2"
            ],
            "metric_group": "distance_from_lot_lines_80_degree_angle",
            "controls": [
              {
                "clause_label_raw": "28CE(2)(a)",
                "clause_path": [
                  "28CE",
                  "2",
                  "a"
                ],
                "condition_text": "distance from any part of the building to any official street line shall be not less than 20 feet measured at right angles",
                "exception_text": "may be reduced to 10 feet if the relevant part of the building is entirely contained within the arms of an 80 degree horizontal angle as determined in subsection (3)"
              },
              {
                "clause_label_raw": "28CE(2)(b)",
                "clause_path": [
                  "28CE",
                  "2",
                  "b"
                ],
                "condition_text": "distance from any part of the building to any lot line other than an official street line shall be not less than 10 feet measured at right angles"
              },
              {
                "clause_label_raw": "28CE(2)(c)",
                "clause_path": [
                  "28CE",
                  "2",
                  "c"
                ],
                "condition_text": "all windows and doors serving habitable rooms shall be located not less than 10 feet from any lot line measured at right angles"
              }
            ]
          },
          {
            "section_label_raw": "28CE(3)",
            "section_path": [
              "28CE",
              "3"
            ],
            "metric_group": "size_of_building_60_degree_angle",
            "controls": [
              {
                "clause_label_raw": "28CE(3)(a)",
                "clause_path": [
                  "28CE",
                  "3",
                  "a"
                ],
                "condition_text": "subject to subsection (2), the building shall not project beyond the angular planes determined over the lot",
                "subcontrols": [
                  {
                    "clause_label_raw": "28CE(3)(a)(i)",
                    "clause_path": [
                      "28CE",
                      "3",
                      "a",
                      "i"
                    ],
                    "condition_text": "from each lot line at natural or finished ground level, whichever is lower, at a vertical angle of 60 degrees above the horizontal, measured perpendicular to such lot line or the tangents of a curved lot line"
                  },
                  {
                    "clause_label_raw": "28CE(3)(a)(ii)",
                    "clause_path": [
                      "28CE",
                      "3",
                      "a",
                      "ii"
                    ],
                    "condition_text": "where a lot line coincides with an official street line, from the centre line of the street or an intervening parallel line",
                    "subcontrols": [
                      {
                        "clause_label_raw": "28CE(3)(a)(ii)(A)",
                        "clause_path": [
                          "28CE",
                          "3",
                          "a",
                          "ii",
                          "A"
                        ],
                        "condition_text": "the distance from the line on which the plane is constructed to the lot line does not exceed 30 feet"
                      },
                      {
                        "clause_label_raw": "28CE(3)(a)(ii)(B)",
                        "clause_path": [
                          "28CE",
                          "3",
                          "a",
                          "ii",
                          "B"
                        ],
                        "condition_text": "the 60 degree vertical angle is constructed perpendicular to the line or tangents of the curved line"
                      }
                    ]
                  }
                ]
              },
              {
                "clause_label_raw": "28CE(3)(b)",
                "clause_path": [
                  "28CE",
                  "3",
                  "b"
                ],
                "condition_text": "any part of the building may project beyond the prescribed 60 degree angular plane if the projection subtends a horizontal angle not exceeding 80 degrees and the extremities of the projection are enclosed by the arms of that angle"
              }
            ]
          },
          {
            "section_label_raw": "28CE(4)",
            "section_path": [
              "28CE",
              "4"
            ],
            "metric_group": "distance_between_external_walls",
            "controls": [
              {
                "clause_label_raw": "28CE(4)(a)",
                "clause_path": [
                  "28CE",
                  "4",
                  "a"
                ],
                "metric_group": "definitions",
                "subcontrols": [
                  {
                    "clause_label_raw": "28CE(4)(a)(i)",
                    "clause_path": [
                      "28CE",
                      "4",
                      "a",
                      "i"
                    ],
                    "definition_text": "\"Base line\" means, in the case of a wall rising from the ground, the natural or finished level of the ground adjoining the base of the wall, whichever is lower, and in all other cases the lowest line of the wall above the natural or finished ground level, whichever is lower."
                  },
                  {
                    "clause_label_raw": "28CE(4)(a)(ii)",
                    "clause_path": [
                      "28CE",
                      "4",
                      "a",
                      "ii"
                    ],
                    "definition_text": "A wall supported above posts, pillars, or other open construction is deemed to rise from the ground, and the base line is the line where the downward projection of the wall meets the lower of natural or finished ground."
                  },
                  {
                    "clause_label_raw": "28CE(4)(a)(iii)",
                    "clause_path": [
                      "28CE",
                      "4",
                      "a",
                      "iii"
                    ],
                    "definition_text": "Where external walls are not parallel but the angle of divergence does not exceed 85 degrees, the walls are deemed to face each other."
                  }
                ]
              },
              {
                "clause_label_raw": "28CE(4)(b)",
                "clause_path": [
                  "28CE",
                  "4",
                  "b"
                ],
                "condition_text": "subsection (4) applies only if any part of the building is erected within the arms of horizontal angles of 65 degrees constructed outwards from the nearest extremities of external walls that face each other"
              },
              {
                "clause_label_raw": "28CE(4)(c)",
                "clause_path": [
                  "28CE",
                  "4",
                  "c"
                ],
                "condition_text": "distance between external walls that face each other shall be not less than 50 feet, and no part of the building shall project beyond 40 degree angular planes measured from the base line of each such wall"
              },
              {
                "clause_label_raw": "28CE(4)(d)",
                "clause_path": [
                  "28CE",
                  "4",
                  "d"
                ],
                "condition_text": "where two facing external walls contain no door or window serving a habitable room, clause (c) does not apply but the distance between such walls shall not be less than 6 feet"
              }
            ]
          },
          {
            "section_label_raw": "28CE(5)",
            "section_path": [
              "28CE",
              "5"
            ],
            "metric_group": "balconies_cornices_eaves_canopies",
            "controls": [
              {
                "clause_label_raw": "28CE(5)(a)",
                "clause_path": [
                  "28CE",
                  "5",
                  "a"
                ],
                "condition_text": "separate individual balconies open on three sides, cornices, eaves and canopies may project through the angular planes, provided any part of such balcony, cornice or eave is not less than 10 feet from any lot line"
              },
              {
                "clause_label_raw": "28CE(5)(b)",
                "clause_path": [
                  "28CE",
                  "5",
                  "b"
                ],
                "condition_text": "canopies may project to within 5 feet of the street line"
              }
            ]
          }
        ]
      },
