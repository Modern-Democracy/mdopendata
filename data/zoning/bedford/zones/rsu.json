  "content_blocks": [
    {
      "heading_context_raw": "PART 6: RESIDENTIAL SINGLE DWELLING UNIT (RSU) ZONE",
      "text": "No development permit shall be issued in a Residential Single Dwelling Unit (RSU) Zone except"
    },
    {
      "heading_context_raw": "for one or more of the following uses:",
      "text": "Zone requirements; (RC-May 23/24;E-June 13/24) unit; (RC-Aug 9/22;E-Sep 15/22)"
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS RSU",
      "text": "In any Residential Single Dwelling Unit (RSU) Zone, no development permit shall be issued"
    },
    {
      "heading_context_raw": "except in conformity with the following requirements:",
      "text": "Minimum Lot Area ........................................................................................ 6,000 Sq. Ft. serviced; Minimum Lot Frontage ............................................................................................................ 60 Ft. Minimum Front Yard .............................. Local and Collector Streets 15 Ft.; 30 Ft. Arterial Streets Minimum Rear Yard ................................................................................................................ 20 Ft. Minimum Side Yard .................................................................................................................. 8 Ft. Minimum Flankage Yard ........................ 15 Ft. Local and Collector Streets; 30 Ft. Arterial Streets Maximum Height of Building .................................................................................................. 35 Ft. Maximum Number of Dwelling Units on Lot (not including secondary or backyard suites) (NWCC-Mar 8/21;E-Mar 27/21) ...................1 Maximum Lot Coverage ............................................................................................................ 35%"
    }
  ],
