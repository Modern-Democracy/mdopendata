  "content_blocks": [
    {
      "heading_context_raw": "PART 23: PARK OPEN SPACE (POS) ZONE",
      "text": "No Development Permit shall be issued in a Park Open Space (POS) Zone except for one or more"
    },
    {
      "heading_context_raw": "of the following uses:",
      "text": "pavilion/interpretative centre."
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS POS:",
      "text": "In any Park Open Space (POS) Zone, no development permit shall be issued for a building except"
    },
    {
      "heading_context_raw": "in conformity with the following requirements:",
      "text": "Minimum Lot Area .......................................................................................................20,000 sq. ft. Minimum Lot Frontage ............................................................................................................. 60 ft. Minimum Front & Flankage Yards.......................... Local Street 20 ft.; Collector or Arterial 30 ft. Minimum Rear Yard ................................................................................................................. 20 ft. Minimum Side Yard ................................................................................................................... 8 ft. Maximum Height of Building ................................................................................................... 20 ft. Maximum Lot Coverage ............................................................................................................ 10%"
    }
  ],
