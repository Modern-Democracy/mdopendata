  "content_blocks": [
    {
      "heading_context_raw": "PART 20: INSTITUTIONAL (SI) ZONE",
      "text": "No development permit shall be issued in an Institutional (SI) Zone except for one or more of the"
    },
    {
      "heading_context_raw": "following uses:",
      "text": ""
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS SI",
      "text": "In any Institutional (SI) Zone, no development permit shall be issued except in conformity with"
    },
    {
      "heading_context_raw": "the following requirements:",
      "text": "Minimum Lot Area ........................................................................................................10,000 sq. ft Minimum Lot Frontage ........................................................................................................... 100 ft. Minimum Front Yard ................................................ Local Street 20 ft; Collector or Arterial 30 ft. Minimum Rear Yard ................................................................................................................. 20 ft. Minimum Side Yard ........................... 8 ft., or half the height of the building, whichever is greater Flankage Yard ...................................................... Local Street 20 ft; Collector or Arterial 30 ft. Maximum Height of Building ................................................................................................... 35 ft. Lot Coverage ....................................................................................................................... 35%"
    }
  ],
