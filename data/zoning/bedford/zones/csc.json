  "requirement_sections": [],
  "content_blocks": [
    {
      "heading_context_raw": "PART 13: SHOPPING CENTRE (CSC) ZONE",
      "text": "No Development Permit shall be issued in a Shopping Centre (CSC) Zone except for one or more"
    },
    {
      "heading_context_raw": "of the following uses:",
      "text": "a) Shopping Centres containing any of the following uses;"
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS CSC",
      "text": "In any Shopping Centre (CSC) Zone, no development permit shall be issued except in conformity"
    },
    {
      "heading_context_raw": "with the following requirements:",
      "text": "Minimum Lot Area ............................................................................................................... 5 Acres Minimum Lot Frontage .......................................................................................................... 500 Ft. Minimum Front Yard ...................................................................................................30 Ft.Setback Minimum Rear Yard ...................................... 0 Ft., except 40 Ft. where abutting a residential zone Minimum Side Yard ...................................... 0 Ft., except 40 Ft. where abutting a residential zone Maximum Height ............................................................................ 52 Ft.(Four floors above grade) Lot Coverage Maximum ............................................................................................................ 50%"
    },
    {
      "heading_context_raw": "SPECIAL REQUIREMENTS - TAVERNS AND LOUNGES",
      "text": "a) Drinking establishments located within shopping centres shall not exceed an area of 3300 square feet devoted to public use."
    }
  ],
