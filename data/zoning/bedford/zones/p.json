  "content_blocks": [
    {
      "heading_context_raw": "PART 22: PARK (P) ZONE",
      "text": "No development permit shall be issued in a Park (P) Zone except for one or more of the following"
    },
    {
      "heading_context_raw": "uses:",
      "text": "a) community and recreational centres; b) playgrounds, playing fields; c) recreational uses; d) public parks; e) uses of a similar nature to the foregoing; f) any uses accessory to the foregoing uses including a refreshment booth or pavilion;"
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS P",
      "text": "In any Park (P) Zone, no development permit shall be issued for a building except in conformity"
    },
    {
      "heading_context_raw": "with the following requirements:",
      "text": "Minimum Lot Area .........................................................................................................6,000 sq. ft. Minimum Lot Frontage ............................................................................................................. 60 ft. Minimum Front Yard ............................................... Local Street 20 ft.; Collector or Arterial 30 ft. Minimum Rear Yard ................................................................................................................. 20 ft. Minimum Side Yard ............................ 8 ft. or half the height of the building, whichever is greater Minimum Flankage Yard ......................................... Local Street 20 ft.; Collector or Arterial 30 ft. Maximum Height of Building ................................................................................................... 35 ft. Maximum Lot Coverage ............................................................................................................ 35%"
    }
  ],
