  "content_blocks": [
    {
      "heading_context_raw": "PART 15: HIGHWAY ORIENTED COMMERCIAL (CHWY) ZONE",
      "text": "No development permit shall be issued in a Highway Oriented Commercial (CHWY) Zone except"
    },
    {
      "heading_context_raw": "for one or more of the following uses:",
      "text": "Zone (RC-Dec 11/25;E-Feb 2/26)"
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS CHWY",
      "text": "In any Highway Oriented Commercial (CHWY) Zone, no development permit shall be issued"
    },
    {
      "heading_context_raw": "except in conformity with the following requirements:",
      "text": "Minimum Lot Area .................................................................................... 20,000 sq. feet Minimum Lot Frontage ................................................................................................. 100 ft. Minimum Front Yard ...................................................................................... 15 ft. setback Minimum Rear Yard ............................ 0 ft., except 40 ft. from property zoned residential Minimum Side Yard ............................ 0 ft., except 40 ft. from property zoned residential Maximum Height of Building ................................................................................................... 35 ft. Maximum Number of Dwelling Units/Lot ......................................................................................0 Lot Coverage .................................................................................................... 50%"
    },
    {
      "heading_context_raw": "SPECIAL REQUIREMENTS: OFFICE USES",
      "text": "Where office uses are not accessory to other permitted uses in this zone, they shall not be located on the ground floor of any building."
    }
  ],
