  "requirement_sections": [],
  "content_blocks": [
    {
      "heading_context_raw": null,
      "text": "PART 15A: CUSHING HILL COMMERCIAL (CHC) ZONE (RC-Dec 10/19;E-Feb 15/20) No development permit shall be issued in a Cushing Hill Commercial (CHC) Zone except for"
    },
    {
      "heading_context_raw": "one or more of the following uses:",
      "text": ""
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS CHWY",
      "text": "In any Cushing Hill Commercial (CHC) Zone, no development permit shall be issued except"
    },
    {
      "heading_context_raw": "in conformity with the following requirements:",
      "text": "Minimum Lot Area ............................................................................................................. 25,000 sq. feet Minimum Lot Frontage............................................................................................................. 100 ft. Minimum Front Yard \u2026\u2026...................................................................................................20 ft. setback Minimum Rear Yard\u2026\u2026\u2026........................8 ft., except 40 ft. from property zoned residential Minimum Side Yard....................................8 ft., except 40 ft. from property zoned residential Maximum Height of Building ..................................................60 ft above the Bedford Highway Maximum Number of Dwelling Units/Lot .........................................................................\u2026\u202632 Lot Coverage ............................................................................................................................50%"
    },
    {
      "heading_context_raw": "SPECIAL REQUIREMENTS: OFFICE USES",
      "text": "Where office uses are not accessory to other permitted uses in this zone, they shall not be located on the ground floor of any building."
    }
  ],
