    {
      "heading_context_raw": "PART 21: UTILITIES (SU) ZONE",
      "text": "No development permit shall be issued in a Utilities (SU) Zone except for one or more of the"
    },
    {
      "heading_context_raw": "following requirements:",
      "text": "a) telephone switching stations; b) electrical substations; c) public water reservoirs, d) public sewage treatment plants; e) natural gas facilities; f) highway utilities; g) telecommunications towers; h) recycling depot i) any uses accessory to the foregoing uses."
    },
    {
      "heading_context_raw": "ZONE REQUIREMENTS SU",
      "text": "In any Utilities (SU) Zone, no development permit shall be issued except in conformity with the"
    },
    {
      "heading_context_raw": "following requirements:",
      "text": "Minimum Lot Area .........................................................................................................6,000 sq. ft. Minimum Lot Frontage ............................................................................................................. 60 ft. Minimum Front Yard ................................................Local Street 20 ft., Collector or Arterial 30 ft. Minimum Rear Yard ................................................................................................................. 20 ft. Minimum Side Yard ................................................................................................................... 8 ft. Minimum Flankage Yard ........................................... Local Street 20 ft, Collector or Arterial 30 ft. Maximum Height of Building ................................................................................................... 35 ft. Lot Coverage ....................................................................................................................... 35%"
    }
  ],
