      },
      "provisions": [
        {
          "provision_label_raw": "7.11.1",
          "clause_path": [
            "7.11.1"
          ],
          "text": "Attached Residential Garages shall not project closer to the Front Lot Line than the front wall of the main Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.11.2",
          "clause_path": [
            "7.11.2"
          ],
          "text": "Attached Residential parking Garages shall be permitted where the width of the Garage is no greater than 50% of the width of the main Building's front façade.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.11.3",
          "clause_path": [
            "7.11.3"
          ],
          "text": "Where a Parking Structure fronts on a Street:",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "a",
          "text": "The ground-level façade shall incorporate retail, public or other active uses, as well as provide pedestrian amenities such as an Awning, Canopy, or sheltered entryway; and",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          },
          "clause_path": [
            "7.11.3",
            "a"
          ]
        },
        {
          "provision_label_raw": "b",
          "text": "The front façade shall be designed to conceal the parking levels and gives the visual appearance of a multi-Storey Building articulated with bays and window openings.",
          "status": "active",
          "citations": {
            "pdf_page_start": 59,
            "pdf_page_end": 59,
            "bylaw_page_start": 59,
            "bylaw_page_end": 59
          },
          "clause_path": [
            "7.11.3",
            "b"
          ]
        }
      ]
    },
    {
      "order_index": 13,
      "section_label_raw": "7.12",
      "title_label_raw": "STOREFRONTS",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 59,
        "pdf_page_end": 59,
        "bylaw_page_start": 59,
        "bylaw_page_end": 59
      },
      "provisions": [
        {
          "provision_label_raw": "7.12.1",
          "clause_path": [
            "7.12.1"
          ],
          "text": "Storefronts and other ground floor non-Residential uses shall have a consistent amount of windows and doors on the front façade as those of traditional Buildings on the Street.",
          "status": "active",
          "citations": {
            "pdf_page_start": 59,
            "pdf_page_end": 59,
            "bylaw_page_start": 59,
            "bylaw_page_end": 59
          }
        },
        {
          "provision_label_raw": "7.12.2",
          "clause_path": [
            "7.12.2"
          ],
          "text": "Reflective or opaque glazing is not permitted for Retail Storefronts.",
          "status": "active",
          "citations": {
            "pdf_page_start": 59,
            "pdf_page_end": 59,
            "bylaw_page_start": 59,
            "bylaw_page_end": 59
          }
        },
        {
          "provision_label_raw": "7.12.3",
          "clause_path": [
            "7.12.3"
          ],
          "text": "An identifiable transition shall be provided between the ground floor storefront and the upper floor of a Building. This transition may consist of a change in material, change in fenestration, or similar means.",
          "status": "active",
          "citations": {
            "pdf_page_start": 59,
            "pdf_page_end": 59,
            "bylaw_page_start": 59,
            "bylaw_page_end": 59
          }
        },
        {
          "provision_label_raw": "7.12.4",
          "clause_path": [
            "7.12.4"
          ],
          "text": "Storefront entrances shall be clearly articulated and shall be located at or near Grade. Split level, raised or sunken entrances are only permitted on Street Frontages with a steep slope and where no other alternative can be feasibly provided.",
          "status": "active",
          "citations": {
            "pdf_page_start": 59,
            "pdf_page_end": 59,
            "bylaw_page_start": 59,
            "bylaw_page_end": 59
          }
        },
        {
          "provision_label_raw": "7.12.5",
          "clause_path": [
            "7.12.5"
          ],
          "text": "Weather protection for pedestrians is permitted over a storefront entranceway through the use of an Awning or Canopy.",
          "status": "active",
          "citations": {
