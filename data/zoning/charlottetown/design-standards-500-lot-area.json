  "sections": [
    {
      "order_index": 2,
      "section_label_raw": "7.1",
      "title_label_raw": "WHERE THESE REGULATIONS APPLY",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 56,
        "pdf_page_end": 56,
        "bylaw_page_start": 56,
        "bylaw_page_end": 56
      },
      "provisions": [
        {
          "provision_label_raw": "7.1.1",
          "clause_path": [
            "7.1.1"
          ],
          "text": "The following regulations shall apply to all Building and Development Permit applications for properties located within the 500 Lot Area, as defined and described in Appendix H.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        },
        {
          "provision_label_raw": "7.1.2",
          "clause_path": [
            "7.1.2"
          ],
          "text": "An exemption to the regulations in this Section may be approved by Council, if supported by a recommendation by the Heritage Board for a Designated Heritage Resource or for a property located within a Heritage Preservation Area as defined in the Heritage Preservation By-law, when the strict adherence to these regulations may negatively impact the integrity and preservation of the Heritage Resource or Heritage Preservation Area.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        }
      ]
    },
    {
      "order_index": 3,
      "section_label_raw": "7.2",
      "title_label_raw": "BUILDING ORIENTATION AND CORNER LOTS",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 56,
        "pdf_page_end": 56,
        "bylaw_page_start": 56,
        "bylaw_page_end": 56
      },
      "provisions": [
        {
          "provision_label_raw": "7.2.1",
          "clause_path": [
            "7.2.1"
          ],
          "text": "All Buildings shall have one primary entrance that faces the Street and has direct access to the sidewalk.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        },
        {
          "provision_label_raw": "7.2.2",
          "clause_path": [
            "7.2.2"
          ],
          "text": "Buildings on Corner Lots shall:",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        },
        {
          "provision_label_raw": "a",
          "text": "Orient to both Street Lot Frontages; and,",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          },
          "clause_path": [
            "7.2.2",
            "a"
          ]
        },
        {
          "provision_label_raw": "b",
          "text": "Architectural features shall wrap the corner of the Building and address the corner condition.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          },
          "clause_path": [
            "7.2.2",
            "b"
          ]
        },
        {
          "provision_label_raw": "7.2.3",
          "clause_path": [
            "7.2.3"
          ],
          "text": "Street access to individual Attached Residential Units (i.e. townhouses) shall be clearly visible, and the scale, rhythm and articulation of the front façade shall be consistent with the Residential character of adjacent Residential Buildings.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        }
      ]
    },
    {
      "order_index": 4,
      "section_label_raw": "7.3",
      "title_label_raw": "FRONT FAÇADE HEIGHT AND WIDTH",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 56,
        "pdf_page_end": 56,
        "bylaw_page_start": 56,
        "bylaw_page_end": 56
      },
      "provisions": [
        {
          "provision_label_raw": "7.3.1",
          "clause_path": [
            "7.3.1"
          ],
          "text": "The primary plane of the front façade shall not appear taller than traditional Buildings on the Street, unless the adjacent Building marks an identifiable transition in Building style and/or land use.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        },
        {
          "provision_label_raw": "7.3.2",
          "clause_path": [
            "7.3.2"
          ],
          "text": "Building elements that are taller than the primary plane of the front façade shall be designed to contrast that of the lower levels in materials and/or design.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        },
        {
          "provision_label_raw": "7.3.3",
          "clause_path": [
            "7.3.3"
          ],
          "text": "A single wall plane on the front facade shall not exceed the maximum façade width of the traditional Buildings on the Street unless the adjacent Building marks an identifiable transition in Building style and/or land use.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        },
        {
          "provision_label_raw": "7.3.4",
          "clause_path": [
            "7.3.4"
          ],
          "text": "For larger or wider Buildings, vertical divisions or bays in the façade at a width consistent with the traditional Buildings on the Street shall be clearly articulated.",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 56,
            "bylaw_page_start": 56,
            "bylaw_page_end": 56
          }
        }
      ]
    },
    {
      "order_index": 5,
      "section_label_raw": "7.4",
      "title_label_raw": "BUILDINGS MATERIALS",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 56,
        "pdf_page_end": 57,
        "bylaw_page_start": 56,
        "bylaw_page_end": 57
      },
      "provisions": [
        {
          "provision_label_raw": "7.4.1",
          "clause_path": [
            "7.4.1"
          ],
          "text": "The Front and Flankage facades shall carry a consistent type and quality of materials. Where a Side Yard Setback is greater than 3 m (9.8 ft), the Side facade shall also carry a consistent material. This clause also applies to the rear façade on a Corner Lot when the Rear Yard is greater than 3 m (9.8 ft).",
          "status": "active",
          "citations": {
            "pdf_page_start": 56,
            "pdf_page_end": 57,
            "bylaw_page_start": 56,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.4.2",
          "clause_path": [
            "7.4.2"
          ],
          "text": "Cement clap-board is not permitted on the Front or Flankage façade of a Building, but may be permitted on the Side or Rear of the Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.4.3",
          "clause_path": [
            "7.4.3"
          ],
          "text": "Vinyl siding is not permitted on the Front or Flank façade of a Building, but may be permitted on the Side or Rear of the Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.4.4",
          "clause_path": [
            "7.4.4"
          ],
          "text": "Materials such as plastic, plywood, concrete block, mirrored glass and metal siding utilizing exposed fasteners are not permitted on the Front and Flankage façades of a Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.4.5",
          "clause_path": [
            "7.4.5"
          ],
          "text": "The appearance of Building materials shall be true to their nature and should not mimic other materials.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.4.6",
          "clause_path": [
            "7.4.6"
          ],
          "text": "Where a prohibited material currently exists it may be maintained and replaced as necessary.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        }
      ]
    },
    {
      "order_index": 6,
      "section_label_raw": "7.5",
      "title_label_raw": "WINDOWS",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 57,
        "pdf_page_end": 57,
        "bylaw_page_start": 57,
        "bylaw_page_end": 57
      },
      "provisions": [
        {
          "provision_label_raw": "7.5.1",
          "clause_path": [
            "7.5.1"
          ],
          "text": "The Front and Flankage facades shall carry a consistent style and material of windows. Where a Side Yard Setback is greater than 3 m (9.8 ft), the Side façade shall also carry a consistent style and material of windows. This clause also applies to the rear façade on a Corner Lot when the Rear Yard is greater than 3 m (9.8 ft).",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.5.2",
          "clause_path": [
            "7.5.2"
          ],
          "text": "The placement and coordination of windows and doors shall create a balanced facade.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.5.3",
          "clause_path": [
            "7.5.3"
          ],
          "text": "Windows on all facades shall vertically and horizontally align with each other and other features of the Structure, when architecturally appropriate for the design of the Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.5.4",
          "clause_path": [
            "7.5.4"
          ],
          "text": "Sliding (patio-style) doors shall not be permitted on the Front or Flankage side of the Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.5.5",
          "clause_path": [
            "7.5.5"
          ],
          "text": "For Additions to, or for a Renovation to an existing Structure with:",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "a",
          "text": "Windows with simulated divided lights with a spacer bar, new windows shall also have simulated divided lights with a spacer bar.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          },
          "clause_path": [
            "7.5.5",
            "a"
          ]
        },
        {
          "provision_label_raw": "b",
          "text": "Single or double hung windows, new windows shall also be single or double hung.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          },
          "clause_path": [
            "7.5.5",
            "b"
          ]
        }
      ]
    },
    {
      "order_index": 7,
      "section_label_raw": "7.6",
      "title_label_raw": "ROOF",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 57,
        "pdf_page_end": 57,
        "bylaw_page_start": 57,
        "bylaw_page_end": 57
      },
      "provisions": [
        {
          "provision_label_raw": "7.6.1",
          "clause_path": [
            "7.6.1"
          ],
          "text": "The expression of the roof shall be clearly distinguished from the rest of the Building through treatments such as step-backs, change in materials, cornices lines, and overhangs when architecturally appropriate for the design of the Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.6.2",
          "clause_path": [
            "7.6.2"
          ],
          "text": "Front facing sloped roofs shall include accent gables, dormers, and a variation of rooflines.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.6.3",
          "clause_path": [
            "7.6.3"
          ],
          "text": "The soffit shall have a consistent overhang typical of the streetscape.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        }
      ]
    },
    {
      "order_index": 8,
      "section_label_raw": "7.7",
      "title_label_raw": "SECONDARY STRUCTURES ON A ROOF",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 57,
        "pdf_page_end": 58,
        "bylaw_page_start": 57,
        "bylaw_page_end": 58
      },
      "provisions": [
        {
          "provision_label_raw": "7.7.1",
          "clause_path": [
            "7.7.1"
          ],
          "text": "Mechanical penthouses shall be integrated within the architectural treatment of roofs shall be screened from view.",
          "status": "active",
          "citations": {
            "pdf_page_start": 57,
            "pdf_page_end": 57,
            "bylaw_page_start": 57,
            "bylaw_page_end": 57
          }
        },
        {
          "provision_label_raw": "7.7.2",
          "clause_path": [
            "7.7.2"
          ],
          "text": "All stacks, gas flues, and roof vents shall not be visible from the Front elevations. Gas flues shall be located near the roof ridge to reduce their Height.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.7.3",
          "clause_path": [
            "7.7.3"
          ],
          "text": "All metal chimneys shall be boxed-in and finished with cladding.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.7.4",
          "clause_path": [
            "7.7.4"
          ],
          "text": "Skylights shall be located on a roof not visible from the Front elevation.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        }
      ]
    },
    {
      "order_index": 9,
      "section_label_raw": "7.8",
      "title_label_raw": "PORCHES",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 58,
        "pdf_page_end": 58,
        "bylaw_page_start": 58,
        "bylaw_page_end": 58
      },
      "provisions": [
        {
          "provision_label_raw": "7.8.1",
          "clause_path": [
            "7.8.1"
          ],
          "text": "A Porch shall be deep enough to allow a seating area with a minimum depth of 1.5m (5 ft).",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.8.2",
          "clause_path": [
            "7.8.2"
          ],
          "text": "The Height of the Porch roof shall align with that of Porches on adjacent or nearby Buildings, and shall be constructed of materials used elsewhere on the Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        }
      ]
    },
    {
      "order_index": 10,
      "section_label_raw": "7.9",
      "title_label_raw": "LANDSCAPING",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 58,
        "pdf_page_end": 58,
        "bylaw_page_start": 58,
        "bylaw_page_end": 58
      },
      "provisions": [
        {
          "provision_label_raw": "7.9.1",
          "clause_path": [
            "7.9.1"
          ],
          "text": "A Landscaped Area shall be provided between the sidewalk and the front façade of the Building, where appropriate for a continuous streetscape.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        }
      ]
    },
    {
      "order_index": 11,
      "section_label_raw": "7.10",
      "title_label_raw": "SURFACE PARKING",
      "chapter_heading_raw": "7 DESIGN STANDARDS FOR THE 500 LOT AREA",
      "citations": {
        "pdf_page_start": 58,
        "pdf_page_end": 58,
        "bylaw_page_start": 58,
        "bylaw_page_end": 58
      },
      "provisions": [
        {
          "provision_label_raw": "7.10.1",
          "clause_path": [
            "7.10.1"
          ],
          "text": "Surface Parking is not permitted in the Front Yard Setback.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.10.2",
          "clause_path": [
            "7.10.2"
          ],
          "text": "Driveways may be permitted when they extend into the Side or Rear Yard of the property, or when used to access an Attached Garage.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.10.3",
          "clause_path": [
            "7.10.3"
          ],
          "text": "Shared driveways and Curb Cuts are permitted with adjacent properties, subject to a Right-of- way agreement between property owners.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.10.4",
          "clause_path": [
            "7.10.4"
          ],
          "text": "Shared parking in an interior courtyard with a single access point is permitted, subject to a Right-of-way agreement between property owners.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.10.5",
          "clause_path": [
            "7.10.5"
          ],
          "text": "Curb Cuts shall accommodate single-car access and the single-car width of the driveway shall be maintained until the driveway extends beyond the front facade of the main Building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 58,
            "pdf_page_end": 58,
            "bylaw_page_start": 58,
            "bylaw_page_end": 58
          }
        },
        {
          "provision_label_raw": "7.10.6",
          "clause_path": [
            "7.10.6"
          ],
          "text": "A Parking Lot shall not be located in the Front or Flankage Yard.",
          "status": "active",
          "citations": {
