      },
      "provisions": [
        {
          "provision_label_raw": "16.5.1",
          "clause_path": [
            "16.5.1"
          ],
          "text": "An existing Dwelling may be Altered and used as a Duplex, Semi-detached or a Multi-unit Dwelling provided that:",
          "status": "active",
          "citations": {
            "pdf_page_start": 73,
            "pdf_page_end": 73,
            "bylaw_page_start": 73,
            "bylaw_page_end": 73
          }
        },
        {
          "provision_label_raw": "a",
          "clause_path": [
            "16.5.1",
            "a"
          ],
          "text": "The Building is structurally sound and the conversion satisfies the requirements under the City of Charlottetown Building Code By-law.",
          "status": "active",
          "citations": {
            "pdf_page_start": 73,
            "pdf_page_end": 73,
            "bylaw_page_start": 73,
            "bylaw_page_end": 73
          }
        },
        {
          "provision_label_raw": "b",
          "clause_path": [
            "16.5.1",
            "b"
          ],
          "text": "The conversion can be undertaken without extreme Alterations or Additions excepting the construction or addition of new windows, fire escapes and outside stairways;",
          "status": "active",
          "citations": {
            "pdf_page_start": 73,
            "pdf_page_end": 73,
            "bylaw_page_start": 73,
            "bylaw_page_end": 73
          }
        },
        {
