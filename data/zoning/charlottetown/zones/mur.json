                  {
                    "cell_id": "zone-mur-table-21-2-row-1-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
