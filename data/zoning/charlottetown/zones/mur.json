                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-2-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "Within the MUR Zone the following Building forms shall be permitted on any Block in the percentages indicated:"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-2-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "column_id": "density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "cell_text_raw": "Within the MUR Zone the following Building forms shall be permitted on any Block in the percentages indicated:"
                  }
                ]
              },
              {
                "row_id": "zone-mur-table-21-2-row-3",
                "source_order": 3,
                "cells_raw": [
                  {
                    "cell_id": "zone-mur-table-21-2-row-3-row-number",
                    "column_id": "row_number",
                    "cell_text_raw": "a"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-3-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "Semi-detached and Duplex Dwellings shall be permitted on up to 25% of the Lots; 25% of the Lots;"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-3-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "column_id": "density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "cell_text_raw": "Semi-detached and Duplex Dwellings shall be permitted on up to 25% of the Lots; 25% of the Lots;"
                  }
                ]
              },
              {
                "row_id": "zone-mur-table-21-2-row-4",
                "source_order": 4,
                "cells_raw": [
                  {
                    "cell_id": "zone-mur-table-21-2-row-4-row-number",
                    "column_id": "row_number",
                    "cell_text_raw": "c"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-4-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "Single-detached Dwellings shall be permitted on up to 35% of the Lots; and"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-4-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "column_id": "density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "cell_text_raw": "Single-detached Dwellings shall be permitted on up to 35% of the Lots; and"
                  }
                ]
              },
              {
                "row_id": "zone-mur-table-21-2-row-5",
                "source_order": 5,
                "cells_raw": [
                  {
                    "cell_id": "zone-mur-table-21-2-row-5-row-number",
                    "column_id": "row_number",
                    "cell_text_raw": "d"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-5-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "Institutional Uses as permitted in the R-3 Zone shall be permitted on up to 15% of the Lots. However, if the percentage for Institutional Uses is not used than the percentage allocated to this use can be allocated in 1/3 increments for the remaining uses as stipulated in this section or the remaining portion can be allocated in whole to Single-detached Dwellings."
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-5-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "column_id": "density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "cell_text_raw": "Institutional Uses as permitted in the R-3 Zone shall be permitted on up to 15% of the Lots. However, if the percentage for Institutional Uses is not used than the percentage allocated to this use can be allocated in 1/3 increments for the remaining uses as stipulated in this section or the remaining portion can be allocated in whole to Single-detached Dwellings."
                  }
                ]
              },
              {
                "row_id": "zone-mur-table-21-2-row-6",
                "source_order": 6,
                "cells_raw": [
                  {
                    "cell_id": "zone-mur-table-21-2-row-6-row-number",
                    "column_id": "row_number",
                    "cell_text_raw": "21.2.3"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-6-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "Single-detached, Semi-detached and Duplex Dwellings shall be permitted on adjoining Lots on the same side of the street adjacent to townhouse Dwellings. At least one side of a run of semi- detached or duplex Dwelling must be flanked by a Single-detached Dwelling."
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-6-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "column_id": "density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "cell_text_raw": "Single-detached, Semi-detached and Duplex Dwellings shall be permitted on adjoining Lots on the same side of the street adjacent to townhouse Dwellings. At least one side of a run of semi- detached or duplex Dwelling must be flanked by a Single-detached Dwelling."
                  }
                ]
              },
              {
                "row_id": "zone-mur-table-21-2-row-7",
                "source_order": 7,
                "cells_raw": [
                  {
                    "cell_id": "zone-mur-table-21-2-row-7-row-number",
                    "column_id": "row_number",
                    "cell_text_raw": "21.2.4"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-7-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "No more than three (3) Townhouse Dwellings with a maximum of twelve (12) units total on all three (3) lots shall be permitted to be constructed on adjoining Lots on the same side of the street."
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-7-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "column_id": "density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "cell_text_raw": "No more than three (3) Townhouse Dwellings with a maximum of twelve (12) units total on all three (3) lots shall be permitted to be constructed on adjoining Lots on the same side of the street."
                  }
                ]
              },
              {
                "row_id": "zone-mur-table-21-2-row-8",
                "source_order": 8,
                "cells_raw": [
                  {
                    "cell_id": "zone-mur-table-21-2-row-8-row-number",
                    "column_id": "row_number",
                    "cell_text_raw": "21.2.5"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-8-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "At no time shall more than two (2) Townhouse Dwelling consisting of more than six (6) Dwelling Units be permitted to be constructed on adjoining Lots."
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-8-density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "column_id": "density_building_forms_within_this_zone_shall_consist_of_a_combination_of_townhouse_dwellings_b_townhouses_stacked_townhouses_block_townhouse_dwellings_shall_be_permitted_on_up_to",
                    "cell_text_raw": "At no time shall more than two (2) Townhouse Dwelling consisting of more than six (6) Dwelling Units be permitted to be constructed on adjoining Lots."
                  }
                ]
              },
              {
                "row_id": "zone-mur-table-21-2-row-9",
                "source_order": 9,
                "cells_raw": [
                  {
                    "cell_id": "zone-mur-table-21-2-row-9-row-number",
                    "column_id": "row_number",
                    "cell_text_raw": "21.2.6"
                  },
                  {
                    "cell_id": "zone-mur-table-21-2-row-9-requirement",
                    "column_id": "requirement",
                    "cell_text_raw": "Subdivision of land within the MUR Zone shall be undertaken in Phases. Prior to approval of a Subdivision within the MUR Zone a concept plan shall be submitted for the overall parcel. The concept plan shall indicate the Phases of Development and shall ensure the mixed density formula has been satisfied for the overall parcel of land."
                  },
