    {
      "order_index": 2,
      "section_label_raw": "37.2",
      "title_label_raw": "BUFFER ZONE REQUIREMENTS",
      "citations": {
        "pdf_page_start": 109,
        "pdf_page_end": 109,
        "bylaw_page_start": 109,
        "bylaw_page_end": 109
      },
      "provisions": [
        {
          "provision_label_raw": "37.2.1",
          "clause_path": [
            "37.2.1"
          ],
          "text": "A continuous linear boardwalk connection shall be provided along the waterfront, excluding wharfs and piers.",
          "status": "active",
          "citations": {
            "pdf_page_start": 109,
            "pdf_page_end": 109,
            "bylaw_page_start": 109,
            "bylaw_page_end": 109
          }
        },
        {
          "provision_label_raw": "37.2.2",
          "clause_path": [
            "37.2.2"
          ],
          "text": "Development within the Port Zone shall require a Land Use Buffer from adjacent Buildings of no less than 5m (16.4 ft) in width.",
          "status": "active",
          "citations": {
            "pdf_page_start": 109,
            "pdf_page_end": 109,
            "bylaw_page_start": 109,
            "bylaw_page_end": 109
          }
        },
        {
          "provision_label_raw": "37.2.3",
          "clause_path": [
            "37.2.3"
          ],
          "text": "Acceptable uses for the Land Use Buffer include boardwalk, linear trail, greenway, or Landscaped Area.",
          "status": "active",
          "citations": {
            "pdf_page_start": 109,
            "pdf_page_end": 109,
            "bylaw_page_start": 109,
            "bylaw_page_end": 109
          }
        },
        {
          "provision_label_raw": "37.2.4",
          "clause_path": [
            "37.2.4"
          ],
          "text": "The Land Use Buffer shall be planted with street trees and shrubs at a frequency of one tree for every 8m 26.2 ft) of length along the boundary line.",
          "status": "active",
          "citations": {
            "pdf_page_start": 109,
            "pdf_page_end": 109,
            "bylaw_page_start": 109,
            "bylaw_page_end": 109
          }
        }
      ]
    },
