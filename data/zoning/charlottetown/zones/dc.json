      "provisions": [
        {
          "provision_label_raw": "section",
          "text": "All permitted uses in the DC Zone are subject to the following regulations:",
          "status": "active",
          "citations": {
            "pdf_page_start": 96,
            "pdf_page_end": 96,
            "bylaw_page_start": 96,
            "bylaw_page_end": 96
          }
        },
        {
          "provision_label_raw": "2",
          "text": "Front and Flankage Yard (Minimum) OR Full Block Developments Minimum 0 m (0 ft) and Maximum 1.0m (3.3 ft); OR, Within the minimum and maximum range of the Setbacks of existing Buildings on the Block.",
          "status": "active",
          "citations": {
            "pdf_page_start": 96,
            "pdf_page_end": 96,
            "bylaw_page_start": 96,
            "bylaw_page_end": 96
          }
        },
        {
          "provision_label_raw": "3",
          "text": "Front Yard Projections Maximum 1.5 m (4.9ft); OR Within the minimum and maximum range of the existing Buildings on the Block.",
          "status": "active",
          "citations": {
            "pdf_page_start": 96,
            "pdf_page_end": 96,
            "bylaw_page_start": 96,
            "bylaw_page_end": 96
          }
        },
        {
          "provision_label_raw": "4",
          "text": "Rear/Side Yard (Minimum) Not required unless the Side or Rear Yard is abutting a residential, DN or DMU property; in which case the minimum Setback shall be equal to the Setback of the Building on the adjacent property from the shared Lot Line, OR 6.0 m (19.7 ft) whichever is less.",
          "status": "active",
          "citations": {
            "pdf_page_start": 96,
            "pdf_page_end": 97,
            "bylaw_page_start": 96,
            "bylaw_page_end": 97
          }
        },
        {
          "provision_label_raw": "5",
          "text": "Height Minimum: 7.5 m (24.6ft) Maximum: 15.0 m (49.2 ft)",
          "status": "active",
          "citations": {
            "pdf_page_start": 97,
            "pdf_page_end": 97,
            "bylaw_page_start": 97,
            "bylaw_page_end": 97
          }
        },
        {
          "provision_label_raw": "6",
          "text": "Driveway Access Only permitted for properties with Lot Frontages of 25m (82 ft) or greater. accessed from the side Street.",
          "status": "active",
          "citations": {
            "pdf_page_start": 97,
            "pdf_page_end": 97,
            "bylaw_page_start": 97,
            "bylaw_page_end": 97
          }
        }
      ],
      "table_column_headings_raw": [
        "Interior/Corner Lots",
        "Corner Lots permitted to provide a rear driveway"
      ]
    },
