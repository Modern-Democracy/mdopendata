      "provisions": [
        {
          "provision_label_raw": "section",
          "text": "The Eastern Gateway (EG Zone) is a secondary planning area just north of the waterfront Port area of Charlottetown and at the gateway into Charlottetown from Stratford. The Eastern Gateway includes the Red Shores and Eastlink Centre facilities, plus new public facilities and event grounds, and future public facilities like sports fields, sports arenas, trails, new mixed use development, new residential development and parks and open spaces. Developments in this zone shall proceed by Development Agreement.",
          "status": "active",
          "citations": {
            "pdf_page_start": 163,
