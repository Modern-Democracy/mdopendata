        },
        {
          "provision_label_raw": ".1",
          "text": "Developments in the Eastern Gateway should be generally consistent with the polices and aims of the Charlottetown Official Plan and the Charlottetown Eastern Gateway Waterfront Master Plan (2011)",
          "status": "active",
          "citations": {
            "pdf_page_start": 164,
            "pdf_page_end": 164,
            "bylaw_page_start": 160,
            "bylaw_page_end": 160
          }
        },
        {
          "provision_label_raw": ".2",
          "text": "The Eastern Gateway is conceived as a \"campus-like destination\" integrating civic, recreational, and private uses - a counterpart to Victoria Park on the city's western edge. The vision calls for:",
          "status": "active",
          "citations": {
            "pdf_page_start": 164,
            "pdf_page_end": 164,
            "bylaw_page_start": 160,
            "bylaw_page_end": 160
          }
        },
        {
          "provision_label_raw": "(a)",
          "text": "Enhanced public access to the waterfront.",
          "status": "active",
          "citations": {
            "pdf_page_start": 164,
            "pdf_page_end": 164,
            "bylaw_page_start": 160,
            "bylaw_page_end": 160
          }
        },
        {
          "provision_label_raw": "(b)",
          "text": "Reinforcement of existing neighbourhoods and urban connections.",
          "status": "active",
          "citations": {
            "pdf_page_start": 164,
            "pdf_page_end": 164,
            "bylaw_page_start": 160,
            "bylaw_page_end": 160
          }
        },
        {
          "provision_label_raw": "(c)",
          "text": "Development of a high-quality public realm with strong open-space networks.",
          "status": "active",
          "citations": {
            "pdf_page_start": 164,
            "pdf_page_end": 164,
            "bylaw_page_start": 160,
            "bylaw_page_end": 160
          }
        },
        {
          "provision_label_raw": "(d)",
          "text": "Recognition of the Hillsborough Heritage River and Charlottetown's historic identity.",
          "status": "active",
          "citations": {
            "pdf_page_start": 164,
            "pdf_page_end": 164,
            "bylaw_page_start": 160,
            "bylaw_page_end": 160
          }
        },
        {
          "provision_label_raw": "(e)",
          "text": "Mixed-use parcels (institutional/ commercial/light industrial) along the waterfront (e.g., Maritime Electric site).",
          "status": "active",
          "citations": {
            "pdf_page_start": 164,
            "pdf_page_end": 164,
            "bylaw_page_start": 160,
            "bylaw_page_end": 160
          }
        },
        {
