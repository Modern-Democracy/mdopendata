    {
      "order_index": 6,
      "section_label_raw": "24.6",
      "title_label_raw": "LANDSCAPE REQUIREMENTS",
      "citations": {
        "pdf_page_start": 155,
        "pdf_page_end": 155,
        "bylaw_page_start": 151,
        "bylaw_page_end": 151
      },
      "provisions": [
        {
          "provision_label_raw": ".1",
          "text": "All disturbed areas should be well landscaped using mostly (> 75% quantities) indigenous, low maintenance plants that are well adapted for the local microclimates on each site. Shade tolerant species shall be specified for the north side of buildings or in areas of frequent shade. Similarly, windy sites should be planted with wind tolerant species. Disturbed areas cannot be left without landscaping.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".2",
          "text": "Where grass is being considered for any project:",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(a)",
          "text": "Ensure the grass species is selected is adequate for shade levels on the site.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(b)",
          "text": "Pegged sod is required on all landscaped slopes exceeding 30%. Erosion Control measures must be clearly identified on sloping sites to minimize soil erosion.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(c)",
          "text": "A minimum of 1.5 m wide of Sod strip is required adjoining any asphalt areas, pathways, gravel storage areas, or landscape beds.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(d)",
          "text": "A minimum of 2 m wide strip of sod is required for all drainage swales",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(e)",
          "text": "Any reinstatement of public road right-of-ways must be sodded.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(f)",
          "text": "Hydraulic seeding is permitted in all other areas where sod is not required. Broadcast seed is not permitted unless used for spot repairs.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".3",
          "text": "For any parking lots located in the front yard, a minimum 2 m wide hard surfaced sidewalk shall connect the front door of the building to any adjacent sidewalks adjoining the property if present.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".4",
          "text": "Driveways, parking areas, storage areas, and loading and unloading areas shall be separated from landscaped areas by continuous concrete curbing unless the design is part of a larger stormwater management strategy using rain gardens, engineered wetlands or other stormwater measures.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".5",
          "text": "Slopes shall be no steeper that three (3) horizontal to one (1) vertical, except as an engineered retaining structure. All slopes shall be vegetated (not necessarily grass) and no riprap stone armouring is permitted on any site unless it is not materially visible from any road or sidewalk.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".6",
          "text": "No permanent or temporary structures are permitted in the public road right of way and any disturbance to the public right-of-way shall be reinstated to existing or better condition including damages to trees, grass, lights or power infrastructure. Only driveways and walkways are permitted in the public right-of-way.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".7",
          "text": "All main entries should be well landscaped to a scale that is appropriate for the scale of the building and the importance of the entry sequence.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".8",
          "text": "Every institutional uses with more than 30 employees working in the building must include a well designed outdoor rest area complete with features such as outdoor seating, picnic tables, wind shelter, landscaping, or hardscape areas. The area should be no less than 1.5 m 2 for every employee parking space and the area should be located to maximize use and enjoyment by staff.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".9",
          "text": "The front doors must connect to adjacent sidewalks and parking areas by a hard surfaced walkway no less than 1.8m wide.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".10",
          "text": "All disturbed surfaces shall be sodded or hard surfaced (asphalt, pavers, concrete). Gravel or bare earth is not permitted except within fenced storage compounds (1.8 m min. fence).",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".11",
          "text": "Front yards shall be landscaped with grass and shrub bed(s) at a rate of 0.5 m 2 of shrub bed per metre of frontage and one tree in the front yard for every 8 m of frontage. Decimal results shall round up.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".12",
          "text": "Garbage and refuse containers shall be concealed from the view of adjoining properties and public streets by means of a screening fence of material compatible with the architecture of the building. These screening elements shall be integrated with the concept of the site and building plan; be designed so as not to attract attention; and shall be located in the most inconspicuous manner possible.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".13",
          "text": "Properties that abut residential uses shall include a 3 m wide landscape buffer along the abutting property line that includes:",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(a)",
          "text": "A 1.8 m high (min.) opaque fence",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(b)",
          "text": "One 60 mm caliper tree per 8m of side or rear yard planted in the landscape buffer placed to block light and views.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": "(c)",
          "text": "For buildings that have been set back more than 3 m from the front lot line, no less than one (1) tree shall be planted per front yard.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        },
        {
          "provision_label_raw": ".14",
          "text": "The development officer may forgo these landscape requirements if it can be demonstrated that any of these requirements do not apply on a specific site. In addition, they may require additional requirements on a site specific basis to deal with special site consequences.",
          "status": "active",
          "citations": {
            "pdf_page_start": 155,
            "pdf_page_end": 155,
            "bylaw_page_start": 151,
            "bylaw_page_end": 151
          }
        }
      ]
    }
