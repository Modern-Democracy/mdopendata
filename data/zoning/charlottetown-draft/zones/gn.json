      "provisions": [
        {
          "provision_label_raw": ".1",
          "text": "All driveways shall be hard surfaced with asphalt, concrete or unit pavers. Loose gravel or soil is not permitted.",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": ".2",
          "text": "Only one driveway per 20 m of frontage is permitted to a maximum of 2 driveways per lot. Shared driveways are encouraged between neighbouring properties whenever possible.",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": ".3",
          "text": "A minimum 2 m wide hard surfaced walkway shall link the parking lot to the front door of every building.",
