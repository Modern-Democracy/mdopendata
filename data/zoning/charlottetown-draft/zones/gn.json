          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": ".5",
          "text": "If there are no street trees in the bordering public street right-of-way, each development shall include no less than 1 tree per 10 m of frontage between the building and the street. Decimal results shall be rounded up.",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": ".6",
          "text": "A 3 m landscape buffer is required for any GN properties that border residential zoned properties in the rear yard. Each landscape buffer shall include:",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": "(a)",
          "text": "A 1.8 m high opaque fence along the rear yard",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": "(b)",
          "text": "One tree per 6 m of rear yard border",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": "(c)",
          "text": "Shrub beds at a rate of 2 m 2 per tree consisting of shrubs, annuals or perennials.",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": ".7",
          "text": "All disturbed surfaces shall be seeded, sodded or hydroseeded with grass or meadow mixture or restored to natural condition.",
          "status": "active",
          "citations": {
            "pdf_page_start": 150,
            "pdf_page_end": 150,
            "bylaw_page_start": 146,
            "bylaw_page_end": 146
          }
        },
        {
          "provision_label_raw": ".8",
          "text": "Each grade-related unit must provide no less than 4 m 2 of private outdoor amenity space (patio, balcony, rooftop deck, or small yard) to ensure resident comfort and privacy.",
