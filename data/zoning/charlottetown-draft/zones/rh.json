      "provisions": [
        {
          "provision_label_raw": ".1",
          "text": "All driveways shall be hard surfaced with asphalt, concrete or unit pavers. Loose gravel or soil is not permitted.",
          "status": "active",
          "citations": {
            "pdf_page_start": 104,
            "pdf_page_end": 104,
            "bylaw_page_start": 100,
            "bylaw_page_end": 100
          }
        },
        {
          "provision_label_raw": ".2",
          "text": "Parking in the front yard is only permitted on a hard surfaced driveways or parking spots with no more than one (1) car per driveway.",
          "status": "active",
          "citations": {
            "pdf_page_start": 104,
            "pdf_page_end": 104,
            "bylaw_page_start": 100,
            "bylaw_page_end": 100
          }
        },
        {
          "provision_label_raw": ".3",
          "text": "No more than 40% of the front yard area can be driveway or parking spaces.",
          "status": "active",
          "citations": {
            "pdf_page_start": 104,
            "pdf_page_end": 104,
            "bylaw_page_start": 100,
            "bylaw_page_end": 100
          }
        },
        {
          "provision_label_raw": ".4",
          "text": "A minimum 2 m wide hard surfaced pathway shall link the parking lot to the front door of every building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 104,
            "pdf_page_end": 104,
            "bylaw_page_start": 100,
            "bylaw_page_end": 100
          }
        },
        {
          "provision_label_raw": ".5",
          "text": "No less than two (2) (minimum 2 m high) tree shall be planted on each lot or 0.5 trees per unit, whichever is greater. Decimals shall be rounded up.",
          "status": "active",
          "citations": {
            "pdf_page_start": 104,
            "pdf_page_end": 104,
            "bylaw_page_start": 100,
            "bylaw_page_end": 100
          }
        },
        {
          "provision_label_raw": ".6",
          "text": "No less than 3 m 2 of shrub beds shall be planted per groundfloor unit consisting of shrubs, annuals or perennials.",
          "status": "active",
          "citations": {
            "pdf_page_start": 104,
            "pdf_page_end": 104,
            "bylaw_page_start": 100,
            "bylaw_page_end": 100
          }
        },
        {
          "provision_label_raw": ".7",
          "text": "All disturbed surfaces shall be seeded, sodded or hydroseeded with grass or meadow mixture or restored to natural condition.",
          "status": "active",
          "citations": {
            "pdf_page_start": 104,
            "pdf_page_end": 104,
            "bylaw_page_start": 100,
            "bylaw_page_end": 100
          }
        },
        {
          "provision_label_raw": ".8",
          "text": "Each grade-related unit shall provide no less than 4 m 2 of private outdoor amenity space (patio, balcony, rooftop deck, or small yard) to ensure resident comfort and privacy. Min. 3 m 2 of shrub beds per groundfloor unit",
          "status": "active",
          "citations": {
