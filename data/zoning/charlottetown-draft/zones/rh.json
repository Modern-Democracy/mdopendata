        "bylaw_page_start": 99,
        "bylaw_page_end": 99
      },
      "provisions": [
        {
          "provision_label_raw": ".1",
          "text": "One building per lot is permitted with the exception of cluster housing.",
          "status": "active",
          "citations": {
            "pdf_page_start": 103,
            "pdf_page_end": 103,
            "bylaw_page_start": 99,
            "bylaw_page_end": 99
          }
        },
        {
          "provision_label_raw": ".2",
          "text": "The maximum building height for the RH Zone is four (4) storeys.",
          "status": "active",
          "citations": {
            "pdf_page_start": 103,
            "pdf_page_end": 103,
            "bylaw_page_start": 99,
            "bylaw_page_end": 99
          }
        },
        {
          "provision_label_raw": ".3",
          "text": "A minimum streetwall stepback of 2 m is required above the 3rd storey. The stepback may be less than the minimum requirement for up to 40% of the streetwall.",
          "status": "active",
          "citations": {
            "pdf_page_start": 103,
            "pdf_page_end": 103,
            "bylaw_page_start": 99,
            "bylaw_page_end": 99
          }
        },
        {
          "provision_label_raw": ".4",
          "text": "Any garage (attached or detached) shall not project any closer to the streetline than the longest wall of the attached main dwelling that faces the same streetline.",
          "status": "active",
          "citations": {
            "pdf_page_start": 103,
            "pdf_page_end": 103,
            "bylaw_page_start": 99,
            "bylaw_page_end": 99
          }
        },
        {
          "provision_label_raw": ".5",
          "text": "Garages shall not exceed 50% of the primary building frontage on any streetline to a maximum of 6 m in total.",
          "status": "active",
          "citations": {
            "pdf_page_start": 103,
            "pdf_page_end": 103,
            "bylaw_page_start": 99,
            "bylaw_page_end": 99
          }
        },
        {
          "provision_label_raw": ".6",
          "text": "All street-facing facades shall provide at least one horizontal or vertical facade articulation of no less than 300 mm for no less than 30% of the facade area.",
          "status": "active",
          "citations": {
            "pdf_page_start": 103,
            "pdf_page_end": 103,
            "bylaw_page_start": 99,
            "bylaw_page_end": 99
          }
        },
        {
          "provision_label_raw": ".7",
          "text": "Townhouse clusters shall not exceed 6 consecutive units. Min. Front Yard Setback 6 m Min. Lot Frontage 20 m for Multi-unit, or cluster Figure 12.2 RH Zone Built Form Standards Min. Flanking Setback 6 m Min. Rear Yard Setback 6 m Max. Cluster Plate Size 800 m 2 per building, none for non-clusters Max. Lot Coverage 50%, 60% if half the parking is located underground Max. Building Height 4 Storeys Min. Streetwall Stepback 2 m at 4th Storey for 60% Min. Lot Area 1,100 m 2",
          "status": "active",
          "citations": {
            "pdf_page_start": 103,
            "pdf_page_end": 103,
            "bylaw_page_start": 99,
            "bylaw_page_end": 99
