    {
      "order_index": 5,
      "section_label_raw": "17.5",
      "title_label_raw": "WATERFRONT BOARDWALK",
      "citations": {
        "pdf_page_start": 122,
        "pdf_page_end": 122,
        "bylaw_page_start": 118,
        "bylaw_page_end": 118
      },
      "provisions": [
        {
          "provision_label_raw": ".1",
          "text": "A 6 m (min) wide public boardwalk easement shall be required along all waterfront edges of the DW zone.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".2",
          "text": "The boardwalk shall be built to match the existing standard of a wooden or hard- surfaced unit-paver in coordination with the help of the City and/or CADC.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".3",
          "text": "Buildings shall be set back no less than 2 m from the edge of the public boardwalk.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".4",
          "text": "All groundfloor uses fronting the boardwalk shall include active uses including commercial, cultural, tourism, or food services. These active uses shall be no less than 12 m deep for the full length of the waterfront frontage.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".5",
          "text": "No less than 50% of the waterfront frontage of the building should include a hardscape plaza between the building and the boardwalk if applicable.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".6",
          "text": "Pop-up uses (e.g. mobile carts, seasonal stalls, kiosks, touch tanks), public art installations, and flexible event spaces are permitted and encouraged along the boardwalk edge.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".7",
          "text": "Any groundfloor uses shall include no less than 60% windows and doors along the entire length of the buildings frontage on the waterfront.",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".8",
          "text": "All groundfloor uses on the waterfront shall have a minimum Finished Floor Elevation",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": "(FFE)",
          "text": "of 3.67 m CGVD28",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
        {
          "provision_label_raw": ".9",
          "text": "Blank walls at the base of buildings are not permitted along the boardwalk, but underground parking may be permitted",
          "status": "active",
          "citations": {
            "pdf_page_start": 122,
            "pdf_page_end": 122,
            "bylaw_page_start": 118,
            "bylaw_page_end": 118
          }
        },
