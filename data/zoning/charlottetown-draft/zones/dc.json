    {
      "order_index": 1,
      "section_label_raw": "13.1",
      "title_label_raw": "INTENT",
      "citations": {
        "pdf_page_start": 105,
        "pdf_page_end": 105,
        "bylaw_page_start": 101,
        "bylaw_page_end": 101
      },
      "provisions": [
        {
          "provision_label_raw": "section",
          "text": "The DC zone is celebrated as the historic heart of Charlottetown's downtown core. With a small lot fabric and small block scale compared to other more modern downtowns, the Downtown Core sits at the northwestern gateway to Province House and links to the waterfront via Queen Street. The area supports several large new developments that are sympathetic to the city's rich history and the need to project the City as a modern hub in Atlantic Canada.",
          "status": "active",
          "citations": {
            "pdf_page_start": 105,
            "pdf_page_end": 105,
            "bylaw_page_start": 101,
            "bylaw_page_end": 101
          }
        }
      ]
    },
