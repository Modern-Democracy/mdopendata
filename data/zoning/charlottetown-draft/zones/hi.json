            "bylaw_page_end": 132
          }
        },
        {
          "provision_label_raw": "(c)",
          "text": "Not exceed the height of the principal building.",
          "status": "active",
          "citations": {
            "pdf_page_start": 136,
            "pdf_page_end": 136,
            "bylaw_page_start": 132,
            "bylaw_page_end": 132
