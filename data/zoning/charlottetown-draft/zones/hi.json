        },
        {
          "provision_label_raw": "(a)",
          "text": "Not be permitted in the front yard of the primary building;",
          "status": "active",
          "citations": {
            "pdf_page_start": 136,
            "pdf_page_end": 136,
            "bylaw_page_start": 132,
            "bylaw_page_end": 132
          }
