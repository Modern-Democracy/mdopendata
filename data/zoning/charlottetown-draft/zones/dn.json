            "bylaw_page_start": 114,
            "bylaw_page_end": 114
          }
        },
        {
          "provision_label_raw": "(c)",
          "text": "Any exterior garbage bins or dumpsters are fenced with a minimum 1.8 m high opaque timber fence.",
