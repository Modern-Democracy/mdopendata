            "bylaw_page_start": 114,
            "bylaw_page_end": 114
          }
        },
        {
          "provision_label_raw": "(d)",
          "text": "Where a neighbourhood convenience store or associated parking/loading area directly abuts a residential use, the owner shall provide and maintain a continuous fence no less than 1.8 m high consisting of a wood fencing or masonry wall",
