          "clause_path": [
            "411",
            "d"
          ],
          "heading_context_raw": "Facility Permits Permit Application Requirements",
          "status": "active",
          "citations": {
            "pdf_page_start": 310,
            "pdf_page_end": 310,
            "bylaw_page_start": 310,
            "bylaw_page_end": 310
          },
          "text": "the proposed number, representative types, and height or range of heights of wind turbines to be constructed, including their generating capacity, dimensions, manufacturers, and a description of accessory facilities;"
        },
        {
          "provision_label_raw": "411(e)",
          "clause_path": [
            "411",
            "e"
          ],
          "heading_context_raw": "Facility Permits Permit Application Requirements",
          "status": "active",
          "citations": {
            "pdf_page_start": 310,
            "pdf_page_end": 310,
            "bylaw_page_start": 310,
            "bylaw_page_end": 310
          },
          "text": "identification and location of the lots on which the proposed wind energy facility will be located;"
