          "provision_label_raw": "411(f)",
          "clause_path": [
            "411",
            "f"
          ],
          "heading_context_raw": "Facility Permits Permit Application Requirements",
          "status": "active",
          "citations": {
            "pdf_page_start": 310,
            "pdf_page_end": 310,
            "bylaw_page_start": 310,
            "bylaw_page_end": 310
