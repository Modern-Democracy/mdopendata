            "pdf_page_start": 349,
            "pdf_page_end": 349,
            "bylaw_page_start": 349,
            "bylaw_page_end": 349
          },
          "text": "on a registered heritage property;"
        },
        {
          "provision_label_raw": "454(2)(c)",
          "clause_path": [
            "454",
            "2",
            "c"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 349,
            "pdf_page_end": 349,
            "bylaw_page_start": 349,
            "bylaw_page_end": 349
          },
          "text": "for a change of use within an existing structure; or"
        },
        {
          "provision_label_raw": "454(2)(d)",
          "clause_path": [
            "454",
            "2",
            "d"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "for an addition that is less than 500 square metres of floor area."
        },
        {
          "provision_label_raw": "454(3)",
          "clause_path": [
            "454",
            "3"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "Any required off-street loading space shall be located on the same lot as the use it is intended to serve."
        },
        {
          "provision_label_raw": "454(4)",
          "clause_path": [
            "454",
            "4"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "Any required off-street loading space shall be surfaced with a hard material such as asphalt, concrete, and permeable pavers, and delineated by concrete curbs or painted lines."
        },
        {
          "provision_label_raw": "454(5)",
          "clause_path": [
            "454",
            "5"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
