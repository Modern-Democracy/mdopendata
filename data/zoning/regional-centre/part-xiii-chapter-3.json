            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "Subject to Subsection 454(6), any required off-street loading space shall be located:"
        },
        {
          "provision_label_raw": "454(5)(a)",
          "clause_path": [
            "454",
            "5",
            "a"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "internal to a building;"
        },
        {
          "provision_label_raw": "454(5)(b)",
          "clause_path": [
            "454",
            "5",
            "b"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "in a parking structure; or"
        },
        {
          "provision_label_raw": "454(5)(c)",
          "clause_path": [
            "454",
            "5",
            "c"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "in any area of a lot where an accessory parking lot is permitted in Sections 442, 443, and 444."
        },
        {
          "provision_label_raw": "454(6)",
          "clause_path": [
            "454",
            "6"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "For a multi-unit dwelling use that contains 120 units or less, an off-street loading space may be located within a driving aisle, providing there is unobstructed access within the driving aisle of 3.0 metres to enable vehicles to maneuver around the loading space."
        },
        {
          "provision_label_raw": "454(7)",
          "clause_path": [
            "454",
            "7"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "The driving access to an off-street loading space shall meet the width and height requirements of Sections 455 or 456."
        },
        {
          "provision_label_raw": "454(8)",
          "clause_path": [
            "454",
            "8"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "The screening requirements for required off-street loading spaces are provided in Section 425."
        },
        {
          "provision_label_raw": "454(9)",
          "clause_path": [
            "454",
            "9"
          ],
          "heading_context_raw": "Loading Off-Street Loading Space",
          "status": "active",
          "citations": {
            "pdf_page_start": 350,
            "pdf_page_end": 350,
            "bylaw_page_start": 350,
            "bylaw_page_end": 350
          },
          "text": "An off-street loading space shall not be used for motor vehicle parking. Type A Off-Street Loading Space"
        }
