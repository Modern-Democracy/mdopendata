    "source_bylaw_data_dir": "data/zoning/charlottetown/zones",
    "purpose": "Lookup from raster map legend codes to current Charlottetown bylaw zoning codes for parcel-level zoning attribution.",
    "notes": [
      "ZONING NOT ASSIGNED and INFILL AREA are map classes, not bylaw zoning codes.",
      "Raster sampling should assign map_legend_code first, then derive zoning_code from this lookup.",
      "Map classes with null zoning_code must remain separate final dissolve classes."
    ]
  },
  "fields": {
    "zoning_code": "Current bylaw zoning code. Null for pseudo-zone map classes.",
    "zone_name": "Current bylaw zone name or pseudo-zone map class name.",
    "map_legend_code": "Code printed in the March 9, 2026 zoning map legend.",
    "zone_file": "Relative path to extracted current bylaw zone JSON, where applicable.",
    "is_bylaw_zone": "True when the class has an actual zoning code in the current bylaw.",
    "is_pseudo_zone": "True for map legend classes that are not assigned actual zoning codes.",
    "final_class_code": "Stable class code to use for parcel attribution and dissolve."
  },
