{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/mdopendata/code-table-seed.schema.json",
  "title": "Code Table Seed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code_table",
    "description",
    "version",
    "seeded_at",
    "entries"
  ],
  "properties": {
    "code_table": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "seeded_at": {
      "type": "string",
      "format": "date"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/code_table_entry"
      }
    }
  },
  "$defs": {
    "code_table_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "label",
        "description",
        "status"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "active",
            "deprecated",
            "review"
          ]
        },
        "symbol": {
          "type": "string"
        },
        "measure_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "default_join_behavior": {
          "enum": [
            "include_target_values",
            "reference_only",
            "override_target_values",
            "exclude_target_values"
          ]
        },
        "sort_order": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
