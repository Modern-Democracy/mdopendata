{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/charlottetown/bylaw-extraction.schema.json",
  "title": "Charlottetown Bylaw Extraction Template Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_metadata",
    "raw_data",
    "structured_data",
    "review_flags"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "document_metadata": {
      "$ref": "#/$defs/document_metadata"
    },
    "raw_data": {
      "$ref": "#/$defs/raw_data"
    },
    "structured_data": {
      "$ref": "#/$defs/structured_data"
    },
    "review_flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_flag"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "document_metadata": {
            "properties": {
              "document_type": {
                "const": "zone"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "document_metadata": {
            "required": [
              "jurisdiction",
              "bylaw_name",
              "source_document_path",
              "document_type",
              "zone_code",
              "zone_name",
              "zone_label_raw",
              "zone_title_raw",
              "citations"
            ]
          },
          "raw_data": {
            "required": [
              "source_units",
              "sections_raw",
              "clause_refs",
              "tables_raw",
              "map_references_raw"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "document_metadata": {
            "properties": {
              "document_type": {
                "enum": [
                  "general_provisions",
                  "design_standards"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "document_metadata": {
            "required": [
              "jurisdiction",
              "bylaw_name",
              "source_document_path",
              "document_type",
              "document_label_raw",
              "document_title_raw",
              "citations"
            ]
          },
          "raw_data": {
            "required": [
              "source_units",
              "sections_raw",
              "clause_refs",
              "tables_raw",
              "map_references_raw"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "document_metadata": {
            "properties": {
              "document_type": {
                "const": "definitions"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "document_metadata": {
            "required": [
              "jurisdiction",
              "bylaw_name",
              "source_document_path",
              "document_type",
              "document_label_raw",
              "document_title_raw",
              "citations"
            ]
          },
          "raw_data": {
            "required": [
              "source_units",
              "entries_raw",
              "clause_refs",
              "tables_raw",
              "map_references_raw"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "document_metadata": {
            "properties": {
              "document_type": {
                "const": "appendix_table"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "document_metadata": {
            "required": [
              "jurisdiction",
              "bylaw_name",
              "source_document_path",
              "document_type",
              "appendix_label_raw",
              "appendix_title_raw",
              "citations"
            ]
          },
          "raw_data": {
            "required": [
              "source_units",
              "pages_raw",
              "clause_refs",
              "tables_raw",
              "map_references_raw"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "document_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jurisdiction",
        "bylaw_name",
        "source_document_path",
        "document_type",
        "citations"
      ],
      "properties": {
        "jurisdiction": {
          "type": "string"
        },
        "bylaw_name": {
          "type": "string"
        },
        "source_document_path": {
          "type": "string"
        },
        "document_type": {
          "enum": [
            "zone",
            "general_provisions",
            "design_standards",
            "definitions",
            "appendix_table",
            "schedule_map",
            "other"
          ]
        },
        "zone_code": {
          "type": "string"
        },
        "zone_name": {
          "type": "string"
        },
        "zone_label_raw": {
          "type": "string"
        },
        "zone_title_raw": {
          "type": "string"
        },
        "document_label_raw": {
          "type": "string"
        },
        "document_title_raw": {
          "type": "string"
        },
        "appendix_label_raw": {
          "type": "string"
        },
        "appendix_title_raw": {
          "type": "string"
        },
        "citations": {
          "$ref": "#/$defs/citation"
        }
      }
    },
    "raw_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_units",
        "clause_refs",
        "tables_raw",
        "map_references_raw"
      ],
      "properties": {
        "source_units": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_unit_raw"
          }
        },
        "sections_raw": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section_raw"
          }
        },
        "clause_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/clause_ref"
          }
        },
        "tables_raw": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/table_raw_ref_or_object"
          }
        },
        "map_references_raw": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/map_reference_raw"
          }
        },
        "entries_raw": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/definition_entry_raw"
          }
        },
        "pages_raw": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/page_raw"
          }
        }
      }
    },
    "structured_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "terms",
        "numeric_values",
        "requirements",
        "regulation_groups",
        "conditional_rule_groups",
        "zone_relationships",
        "map_layer_references",
        "other_requirements"
      ],
      "properties": {
        "terms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/term"
          }
        },
        "uses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/use"
          }
        },
        "numeric_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/numeric_value"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement"
          }
        },
        "regulation_groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/regulation_group"
          }
        },
        "conditional_rule_groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conditional_rule_group"
          }
        },
        "zone_relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        },
        "map_layer_references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/map_reference"
          }
        },
        "other_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement"
          }
        },
        "definitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/definition"
          }
        },
        "cross_references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        },
        "site_specific_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement"
          }
        },
        "spatial_references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/map_reference"
          }
        }
      }
    },
    "term": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term_id",
        "term_raw",
        "term_normalized",
        "term_category",
        "confidence"
      ],
      "properties": {
        "term_id": {
          "type": "string"
        },
        "term_raw": {
          "type": "string"
        },
        "term_normalized": {
          "type": "string"
        },
        "term_category": {
          "enum": [
            "dwelling_type",
            "use_type",
            "accessory_or_secondary_use",
            "lot_context",
            "yard_type",
            "building_element",
            "approval_process",
            "map_feature",
            "document_reference",
            "zone",
            "parking_loading",
            "signage",
            "environmental_feature",
            "unknown"
          ],
          "description": "Stable category intended to become a code table, such as dwelling_type, use_type, lot_context, yard_type, building_element, approval_process, map_feature, or document_reference."
        },
        "code_table": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "numeric_value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "numeric_value_id",
        "value_raw",
        "value",
        "unit",
        "measure_type",
        "comparator",
        "confidence"
      ],
      "properties": {
        "numeric_value_id": {
          "type": "string"
        },
        "value_raw": {
          "type": "string"
        },
        "value": {
          "type": [
            "number",
            "null"
          ]
        },
        "unit": {
          "enum": [
            "m",
            "ft",
            "sq_m",
            "sq_ft",
            "ha",
            "acre",
            "percent",
            "storey",
            "bedroom",
            "dwelling_unit",
            "unit",
            "parking_space",
            "seat",
            "room",
            "sign",
            "per_ha",
            "cad",
            "none",
            null
          ],
          "description": "Use canonical unit codes such as m, ft, sq_m, sq_ft, percent, storey, bedroom, unit, parking_space."
        },
        "measure_type": {
          "enum": [
            "length",
            "area",
            "height",
            "density",
            "count",
            "ratio",
            "percentage",
            "time",
            "currency",
            "angle",
            "unknown"
          ],
          "description": "Stable measure category intended for code tables, such as length, area, height, density, count, ratio, percentage, time, or currency."
        },
        "comparator": {
          "enum": [
            "minimum",
            "maximum",
            "exact",
            "range_min",
            "range_max",
            "less_than",
            "greater_than",
            "at_least",
            "at_most",
            "not_applicable",
            "unknown"
          ],
          "description": "Standard comparison operator such as minimum, maximum, exact, range_min, range_max, less_than, greater_than, at_least, at_most, not_applicable, or unknown."
        },
        "alternative_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternative_numeric_value"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "requirement_type",
        "requirement_category",
        "requirement_text_raw",
        "confidence"
      ],
      "properties": {
        "requirement_id": {
          "type": "string"
        },
        "requirement_type": {
          "enum": [
            "dimensional_standard",
            "permitted_use_rule",
            "prohibited_use_rule",
            "design_standard",
            "process_requirement",
            "agreement_requirement",
            "map_applicability_rule",
            "parking_requirement",
            "permitted_use",
            "parking_space",
            "zoning_map",
            "driveway",
            "development_permit",
            "schedule",
            "application_shall",
            "minimum_lot_frontage",
            "maximum_building_height",
            "loading_space",
            "shall_not_be_permitted",
            "minimum_front_yard",
            "minimum_lot_area",
            "minimum_side_yard",
            "as_shown_on",
            "prohibited_use",
            "minimum_rear_yard",
            "approval_of_council",
            "signage_requirement",
            "environmental_requirement",
            "relationship_rule",
            "other"
          ],
          "description": "Stable type intended for code tables, such as dimensional_standard, permitted_use_rule, prohibited_use_rule, design_standard, process_requirement, agreement_requirement, map_applicability_rule, parking_requirement, signage_requirement, environmental_requirement, or other."
        },
        "requirement_category": {
          "type": "string",
          "description": "Comparable category such as lot_area, lot_frontage, front_yard, rear_yard, side_yard, flankage_yard, height, density, landscaped_area, parking, permitted_use, buffer, bonus_height, storm_surge, or development_agreement."
        },
        "requirement_label_raw": {
          "type": "string"
        },
        "requirement_text_raw": {
          "type": "string"
        },
        "applicability": {
          "$ref": "#/$defs/applicability"
        },
        "numeric_value_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "term_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "regulation_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regulation_group_id",
        "group_title_raw",
        "requirement_refs",
        "confidence"
      ],
      "properties": {
        "regulation_group_id": {
          "type": "string"
        },
        "group_label_raw": {
          "type": "string"
        },
        "group_title_raw": {
          "type": "string"
        },
        "regulated_use_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applicability": {
          "$ref": "#/$defs/applicability"
        },
        "requirement_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_section_ref": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "conditional_rule_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conditional_rule_group_id",
        "rule_group_type",
        "requirement_refs",
        "confidence"
      ],
      "properties": {
        "conditional_rule_group_id": {
          "type": "string"
        },
        "rule_group_type": {
          "type": "string",
          "description": "Examples: bonus_height, walkable_street_grade_use, storm_surge_protection, site_specific_exemption, development_agreement, buffer_requirement."
        },
        "rule_group_title_raw": {
          "type": "string"
        },
        "trigger_conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/condition"
          }
        },
        "requirement_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationship_id",
        "relationship_type",
        "source_ref",
        "target_ref",
        "confidence"
      ],
      "properties": {
        "relationship_id": {
          "type": "string"
        },
        "relationship_type": {
          "enum": [
            "inherits_uses",
            "inherits_regulations",
            "references_section",
            "references_clause",
            "references_table",
            "references_definition",
            "references_zone",
            "references_map_layer",
            "applies_to_parcel",
            "supersedes",
            "exception_to",
            "modifies",
            "implements",
            "notwithstanding",
            "does_not_apply",
            "as_shown_on",
            "except_as_provided",
            "referred_to_in",
            "where_permitted_in",
            "unknown"
          ],
          "description": "Examples: inherits_uses, inherits_regulations, references_section, references_table, references_definition, references_zone, references_map_layer, applies_to_parcel, supersedes, exception_to."
        },
        "source_ref": {
          "$ref": "#/$defs/source_ref"
        },
        "target_ref": {
          "$ref": "#/$defs/source_ref"
        },
        "scope": {
          "type": "string"
        },
        "source_clause_ref": {
          "type": "string"
        },
        "join_behavior": {
          "enum": [
            "include_target_values",
            "reference_only",
            "override_target_values",
            "exclude_target_values"
          ],
          "description": "How query logic should traverse this relationship, such as include_target_values, reference_only, override_target_values, or exclude_target_values."
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "map_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "map_reference_id",
        "map_title_raw",
        "map_reference_type",
        "confidence"
      ],
      "properties": {
        "map_reference_id": {
          "type": "string"
        },
        "map_title_raw": {
          "type": "string"
        },
        "map_label_raw": {
          "type": "string"
        },
        "map_reference_type": {
          "enum": [
            "zoning_map",
            "height_schedule",
            "street_hierarchy",
            "walkable_street_map",
            "site_specific_map",
            "appendix_map",
            "other"
          ],
          "description": "Examples: zoning_map, height_schedule, street_hierarchy, walkable_street_map, site_specific_map, appendix_map."
        },
        "postgis_schema": {
          "type": "string"
        },
        "postgis_table": {
          "type": "string"
        },
        "postgis_layer_name": {
          "type": "string"
        },
        "feature_key": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "use": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "use_id",
        "use_name_raw",
        "use_status",
        "confidence"
      ],
      "properties": {
        "use_id": {
          "type": "string"
        },
        "use_name_raw": {
          "type": "string"
        },
        "use_term_id": {
          "type": "string"
        },
        "use_status": {
          "enum": [
            "permitted",
            "accessory_or_secondary",
            "secondary",
            "conditional",
            "site_specific",
            "prohibited",
            "inherited",
            "unknown"
          ],
          "description": "Examples: permitted, accessory_or_secondary, secondary, conditional, site_specific, prohibited, inherited, unknown."
        },
        "source_clause_ref": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "definition_id",
        "term_raw",
        "definition_text",
        "confidence"
      ],
      "properties": {
        "definition_id": {
          "type": "string"
        },
        "definition_key": {
          "type": "string"
        },
        "term_raw": {
          "type": "string"
        },
        "term_id": {
          "type": "string"
        },
        "definition_text": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        },
        "cross_references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "applies_to_zone_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applies_to_lot_contexts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applies_to_use_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/condition"
          }
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition_text_raw"
      ],
      "properties": {
        "condition_type": {
          "type": "string"
        },
        "condition_text_raw": {
          "type": "string"
        },
        "term_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "numeric_value_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_ref"
          }
        }
      }
    },
    "source_unit_raw": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_unit_id",
        "source_unit_type",
        "source_order",
        "citations"
      ],
      "properties": {
        "source_unit_id": {
          "type": "string"
        },
        "source_unit_type": {
          "type": "string"
        },
        "label_raw": {
          "type": "string"
        },
        "title_raw": {
          "type": "string"
        },
        "text_raw": {
          "type": "string"
        },
        "source_order": {
          "type": "integer"
